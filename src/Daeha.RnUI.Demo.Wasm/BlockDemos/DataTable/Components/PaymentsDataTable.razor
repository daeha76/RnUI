<div class="w-full space-y-4">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold tracking-tight">Payments</h2>
            <p class="text-muted-foreground">Manage your payment transactions.</p>
        </div>
        <RnButton>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
                <path d="M5 12h14"/><path d="M12 5v14"/>
            </svg>
            Add Payment
        </RnButton>
    </div>

    <RnDataTable TItem="PaymentRecord"
                 Items="_payments"
                 SelectionMode="SelectionMode.Multiple"
                 PageSize="10"
                 PageSizeOptions="@(new[] { 5, 10, 20, 50 })"
                 FilterMode="FilterMode.Contains"
                 RowClass="@GetRowClass">
        <Toolbar>
            <div class="flex items-center justify-between w-full">
                <div class="flex flex-1 items-center space-x-2">
                    <RnDataTableSearch TItem="PaymentRecord" Placeholder="Filter payments..." />
                </div>
                <div class="flex items-center space-x-2">
                    <RnDataTableColumnToggle TItem="PaymentRecord" />
                </div>
            </div>
        </Toolbar>
        <Columns>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Id" Title="Transaction" Sortable Width="120px">
                <CellTemplate Context="item">
                    <span class="font-mono text-xs">@item.Id</span>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Status" Title="Status" Sortable Filterable>
                <CellTemplate Context="item">
                    <div class="flex items-center">
                        <span class="@GetStatusDotClass(item.Status)"></span>
                        <RnBadge Variant="@GetStatusVariant(item.Status)" Class="capitalize">
                            @item.Status.ToLower()
                        </RnBadge>
                    </div>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Customer" Title="Customer" Sortable Filterable>
                <CellTemplate Context="item">
                    <div class="flex items-center space-x-3">
                        <RnAvatar Class="h-8 w-8">
                            <RnAvatarFallback>@GetInitials(item.Customer)</RnAvatarFallback>
                        </RnAvatar>
                        <div class="flex flex-col">
                            <span class="font-medium text-sm">@item.Customer</span>
                            <span class="text-xs text-muted-foreground">@item.Email</span>
                        </div>
                    </div>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Method" Title="Method" Sortable Filterable>
                <CellTemplate Context="item">
                    <div class="flex items-center space-x-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="h-4 w-4 text-muted-foreground">
                            <rect width="20" height="14" x="2" y="5" rx="2"/>
                            <line x1="2" x2="22" y1="10" y2="10"/>
                        </svg>
                        <span>@item.Method</span>
                    </div>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Category" Title="Category" Sortable Filterable>
                <CellTemplate Context="item">
                    <RnBadge Variant="BadgeVariant.Outline" Class="text-xs">@item.Category</RnBadge>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Date" Title="Date" Sortable>
                <CellTemplate Context="item">
                    <span class="text-sm text-muted-foreground">@item.Date.ToString("MMM dd, yyyy")</span>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Property="x => x.Amount" Title="Amount" Sortable
                               CellClass="@(item => item.Amount > 500 ? "text-green-600 dark:text-green-400 font-semibold" : null)">
                <CellTemplate Context="item">
                    <div class="text-right font-medium tabular-nums">
                        @item.Amount.ToString("C")
                    </div>
                </CellTemplate>
            </RnDataTableColumn>
            <RnDataTableColumn TItem="PaymentRecord" Title="" Id="actions" Width="50px">
                <CellTemplate Context="item">
                    <RnDataTableRowActions>
                        <RnDropdownMenuLabel>Actions</RnDropdownMenuLabel>
                        <RnDropdownMenuSeparator />
                        <RnDropdownMenuItem>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
                                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                            </svg>
                            Copy ID
                        </RnDropdownMenuItem>
                        <RnDropdownMenuItem>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
                                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                            View Details
                        </RnDropdownMenuItem>
                        <RnDropdownMenuItem>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
                                <path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/>
                            </svg>
                            Edit Payment
                        </RnDropdownMenuItem>
                        <RnDropdownMenuSeparator />
                        <RnDropdownMenuItem Class="text-destructive">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
                                <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                <line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>
                            </svg>
                            Delete
                        </RnDropdownMenuItem>
                    </RnDataTableRowActions>
                </CellTemplate>
            </RnDataTableColumn>
        </Columns>
        <DetailTemplate Context="item">
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Transaction ID</p>
                        <p class="text-sm font-mono mt-1">@item.Id</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Customer</p>
                        <p class="text-sm mt-1">@item.Customer</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Email</p>
                        <p class="text-sm mt-1">@item.Email</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Amount</p>
                        <p class="text-sm font-semibold mt-1">@item.Amount.ToString("C")</p>
                    </div>
                </div>
                <RnSeparator />
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Status</p>
                        <div class="mt-1">
                            <RnBadge Variant="@GetStatusVariant(item.Status)">@item.Status</RnBadge>
                        </div>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Method</p>
                        <p class="text-sm mt-1">@item.Method</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Category</p>
                        <p class="text-sm mt-1">@item.Category</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Date</p>
                        <p class="text-sm mt-1">@item.Date.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>
                <div class="flex gap-2 pt-2">
                    <RnButton Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Download Receipt</RnButton>
                    <RnButton Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Send Reminder</RnButton>
                    <RnButton Size="ButtonSize.Sm" Variant="ButtonVariant.Destructive">Refund</RnButton>
                </div>
            </div>
        </DetailTemplate>
        <EmptyContent>
            <div class="flex flex-col items-center justify-center py-10">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/50 mb-4">
                    <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>
                    <path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/>
                </svg>
                <p class="text-sm font-medium">No payments found</p>
                <p class="text-xs text-muted-foreground mt-1">Try adjusting your search or filter to find what you're looking for.</p>
            </div>
        </EmptyContent>
    </RnDataTable>
</div>

