    ];

    private static string? GetRowClass(PaymentRecord item) => item.Status switch
    {
        "Failed" => "bg-destructive/5",
        _ => null
    };

    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Success" => BadgeVariant.Default,
        "Processing" => BadgeVariant.Secondary,
        "Pending" => BadgeVariant.Outline,
        "Failed" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };

    private static string GetStatusDotClass(string status) => status switch
    {
        "Success" => "mr-2 h-2 w-2 rounded-full bg-green-500",
        "Processing" => "mr-2 h-2 w-2 rounded-full bg-blue-500 animate-pulse",
        "Pending" => "mr-2 h-2 w-2 rounded-full bg-yellow-500",
        "Failed" => "mr-2 h-2 w-2 rounded-full bg-red-500",
        _ => "mr-2 h-2 w-2 rounded-full bg-gray-500"
    };

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}";
        return parts.Length > 0 ? parts[0][..1] : "?";
    }
}
