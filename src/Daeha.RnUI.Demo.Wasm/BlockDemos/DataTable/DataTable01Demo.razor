@using Daeha.RnUI.Demo.Wasm.Models
@using Daeha.RnUI.Demo.Wasm.BlockDemos.DataTable.Components

@code {
    public static BlockDemo GetDemo() => new(
        Name: "DataTable 01",
        Slug: "data-table-01",
        Description: "A full-featured payments data table with sorting, filtering, selection, row expansion, conditional styling, and actions.",
        Category: "data-table",
        Demo: @<div class="w-full p-6 md:p-10">
            <PaymentsDataTable />
        </div>,
        Thumbnail: @<div class="scale-[0.35] origin-top-left pointer-events-none w-[286%] h-[300px] overflow-hidden">
            <div class="p-6">
                <PaymentsDataTable />
            </div>
        </div>,
        Files:
        [
            new("payments-data-table.razor",
                """
                @using RnUI.Components.UI.DataTable

                <div class="w-full space-y-4">
                    <div class="flex items-center justify-between">
                        <div>
                            <h2 class="text-2xl font-bold tracking-tight">Payments</h2>
                            <p class="text-muted-foreground">Manage your payment transactions.</p>
                        </div>
                        <RnButton OnClick="() => _addDialogOpen = true">
                            <PlusIcon class="mr-2 h-4 w-4" />
                            Add Payment
                        </RnButton>
                    </div>

                    <AddPaymentDialog @bind-Open="_addDialogOpen" OnSubmit="HandleAddPayment" />

                    <RnDataTable TItem="PaymentRecord"
                                 Items="_payments"
                                 SelectionMode="SelectionMode.Multiple"
                                 PageSize="10"
                                 PageSizeOptions="@(new[] { 5, 10, 20, 50 })"
                                 RowClass="@GetRowClass">
                        <Toolbar>
                            <div class="flex items-center justify-between w-full">
                                <RnDataTableSearch TItem="PaymentRecord" Placeholder="Filter payments..." />
                                <RnDataTableColumnToggle TItem="PaymentRecord" />
                            </div>
                        </Toolbar>
                        <Columns>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Id" Title="Transaction" Sortable>
                                <CellTemplate Context="item">
                                    <span class="font-mono text-xs">@item.Id</span>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Status" Title="Status" Sortable Filterable>
                                <CellTemplate Context="item">
                                    <RnBadge Variant="@GetStatusVariant(item.Status)">@item.Status</RnBadge>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Customer" Title="Customer" Sortable Filterable />
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Method" Title="Method" Sortable />
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Amount" Title="Amount" Sortable>
                                <HeaderTemplate>
                                    <div class="flex items-center justify-end gap-1.5 w-full">
                                        <DollarSignIcon class="h-3.5 w-3.5 text-muted-foreground" />
                                        <span>Amount</span>
                                    </div>
                                </HeaderTemplate>
                                <CellTemplate Context="item">
                                    <div class="text-right font-medium">@item.Amount.ToString("C")</div>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord" Title="" Id="actions">
                                <CellTemplate Context="item">
                                    <RnDataTableRowActions>
                                        <RnDropdownMenuLabel>Actions</RnDropdownMenuLabel>
                                        <RnDropdownMenuSeparator />
                                        <RnDropdownMenuItem>View Details</RnDropdownMenuItem>
                                        <RnDropdownMenuItem Class="text-destructive">Delete</RnDropdownMenuItem>
                                    </RnDataTableRowActions>
                                </CellTemplate>
                            </RnDataTableColumn>
                        </Columns>
                        <EmptyContent>
                            <div class="py-10 text-center">
                                <p class="font-medium">No payments found</p>
                            </div>
                        </EmptyContent>
                    </RnDataTable>
                </div>

                @code {
                    public record PaymentRecord(string Id, string Customer, string Email,
                        string Status, string Method, string Category, decimal Amount, DateTime Date);

                    private bool _addDialogOpen;
                    private int _nextId = 4;

                    // Important: Use a non-readonly list so you can create a new reference on add
                    private List<PaymentRecord> _payments =
                    [
                        new("TXN-001", "Olivia Martin", "olivia@example.com", "Success", "Visa ****4242", "Subscription", 316.00m, new(2026, 3, 1)),
                        new("TXN-002", "Jackson Lee", "jackson@example.com", "Processing", "PayPal", "One-time", 242.00m, new(2026, 3, 2)),
                        new("TXN-003", "Isabella Nguyen", "isabella@example.com", "Failed", "Visa ****9876", "Refund", 874.00m, new(2026, 3, 3)),
                    ];

                    private void HandleAddPayment(AddPaymentDialog.PaymentFormData data)
                    {
                        var payment = new PaymentRecord(
                            $"TXN-{_nextId++:D3}", data.Customer, data.Email,
                            "Pending", data.Method, data.Category, data.Amount, DateTime.Now);
                        // Immutable update: new list reference triggers Blazor change detection
                        _payments = [.._payments, payment];
                    }

                    private static string? GetRowClass(PaymentRecord item) =>
                        item.Status == "Failed" ? "bg-destructive/5" : null;

                    private static BadgeVariant GetStatusVariant(string status) => status switch
                    {
                        "Success" => BadgeVariant.Default,
                        "Processing" => BadgeVariant.Secondary,
                        "Failed" => BadgeVariant.Destructive,
                        _ => BadgeVariant.Outline
                    };
                }
                """),
            new("page.razor",
                """
                @page "/payments"

                <div class="container mx-auto py-10">
                    <PaymentsDataTable />
                </div>
                """)
        ]
    );
}
