@using Daeha.RnUI.Demo.Wasm.Models
@using Daeha.RnUI.Demo.Wasm.BlockDemos.DataTable.Components

@code {
    public static BlockDemo GetDemo() => new(
        Name: "DataTable 01",
        Slug: "data-table-01",
        Description: "A full-featured payments data table with sorting, filtering, selection, row expansion, conditional styling, and actions.",
        Category: "data-table",
        Demo: @<div class="w-full p-6 md:p-10">
            <PaymentsDataTable />
        </div>,
        Thumbnail: @<div class="scale-[0.35] origin-top-left pointer-events-none w-[286%] h-[300px] overflow-hidden">
            <div class="p-6">
                <PaymentsDataTable />
            </div>
        </div>,
        Files:
        [
            new("payments-data-table.razor",
                """
                @using RnUI.Components.UI.DataTable

                <div class="w-full space-y-4">
                    <div class="flex items-center justify-between">
                        <div>
                            <h2 class="text-2xl font-bold tracking-tight">Payments</h2>
                            <p class="text-muted-foreground">Manage your payment transactions.</p>
                        </div>
                        <RnButton>
                            <PlusIcon class="mr-2 h-4 w-4" />
                            Add Payment
                        </RnButton>
                    </div>

                    <RnDataTable TItem="PaymentRecord"
                                 Items="_payments"
                                 SelectionMode="SelectionMode.Multiple"
                                 PageSize="10"
                                 PageSizeOptions="@(new[] { 5, 10, 20, 50 })"
                                 RowClass="@GetRowClass">
                        <Toolbar>
                            <div class="flex items-center justify-between w-full">
                                <RnDataTableSearch TItem="PaymentRecord" Placeholder="Filter payments..." />
                                <RnDataTableColumnToggle TItem="PaymentRecord" />
                            </div>
                        </Toolbar>
                        <Columns>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Id" Title="Transaction" Sortable>
                                <CellTemplate Context="item">
                                    <span class="font-mono text-xs">@item.Id</span>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Status" Title="Status" Sortable Filterable>
                                <CellTemplate Context="item">
                                    <RnBadge Variant="@GetStatusVariant(item.Status)">
                                        @item.Status
                                    </RnBadge>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Customer" Title="Customer" Sortable Filterable>
                                <CellTemplate Context="item">
                                    <div class="flex items-center space-x-3">
                                        <RnAvatar Class="h-8 w-8">
                                            <RnAvatarFallback>@GetInitials(item.Customer)</RnAvatarFallback>
                                        </RnAvatar>
                                        <div>
                                            <span class="font-medium text-sm">@item.Customer</span>
                                            <span class="text-xs text-muted-foreground block">@item.Email</span>
                                        </div>
                                    </div>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Method" Title="Method" Sortable />
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Category" Title="Category" Sortable Filterable>
                                <CellTemplate Context="item">
                                    <RnBadge Variant="BadgeVariant.Outline">@item.Category</RnBadge>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Date" Title="Date" Sortable>
                                <CellTemplate Context="item">
                                    @item.Date.ToString("MMM dd, yyyy")
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord"
                                               Property="x => x.Amount" Title="Amount" Sortable
                                               CellClass="@(item => item.Amount > 500 ? "text-green-600 font-semibold" : null)">
                                <CellTemplate Context="item">
                                    <div class="text-right font-medium">@item.Amount.ToString("C")</div>
                                </CellTemplate>
                            </RnDataTableColumn>
                            <RnDataTableColumn TItem="PaymentRecord" Title="" Id="actions">
                                <CellTemplate Context="item">
                                    <RnDataTableRowActions>
                                        <RnDropdownMenuLabel>Actions</RnDropdownMenuLabel>
                                        <RnDropdownMenuSeparator />
                                        <RnDropdownMenuItem>Copy ID</RnDropdownMenuItem>
                                        <RnDropdownMenuItem>View Details</RnDropdownMenuItem>
                                        <RnDropdownMenuItem>Edit Payment</RnDropdownMenuItem>
                                        <RnDropdownMenuSeparator />
                                        <RnDropdownMenuItem Class="text-destructive">Delete</RnDropdownMenuItem>
                                    </RnDataTableRowActions>
                                </CellTemplate>
                            </RnDataTableColumn>
                        </Columns>
                        <DetailTemplate Context="item">
                            <div class="p-6 grid grid-cols-4 gap-4">
                                <div>
                                    <p class="text-xs text-muted-foreground">Transaction ID</p>
                                    <p class="text-sm font-mono">@item.Id</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Customer</p>
                                    <p class="text-sm">@item.Customer (@item.Email)</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Method</p>
                                    <p class="text-sm">@item.Method</p>
                                </div>
                                <div>
                                    <p class="text-xs text-muted-foreground">Amount</p>
                                    <p class="text-sm font-semibold">@item.Amount.ToString("C")</p>
                                </div>
                            </div>
                        </DetailTemplate>
                        <EmptyContent>
                            <div class="py-10 text-center">
                                <p class="font-medium">No payments found</p>
                                <p class="text-xs text-muted-foreground mt-1">
                                    Try adjusting your search or filter.
                                </p>
                            </div>
                        </EmptyContent>
                    </RnDataTable>
                </div>

                @code {
                    public record PaymentRecord(
                        string Id, string Customer, string Email, string Status,
                        string Method, string Category, decimal Amount, DateTime Date);

                    private readonly List<PaymentRecord> _payments = [ /* your data */ ];

                    private static string? GetRowClass(PaymentRecord item) =>
                        item.Status == "Failed" ? "bg-destructive/5" : null;

                    private static BadgeVariant GetStatusVariant(string status) => status switch
                    {
                        "Success" => BadgeVariant.Default,
                        "Processing" => BadgeVariant.Secondary,
                        "Pending" => BadgeVariant.Outline,
                        "Failed" => BadgeVariant.Destructive,
                        _ => BadgeVariant.Outline
                    };

                    private static string GetInitials(string name)
                    {
                        var parts = name.Split(' ');
                        return parts.Length >= 2 ? $"{parts[0][0]}{parts[^1][0]}" : name[..1];
                    }
                }
                """),
            new("page.razor",
                """
                @page "/payments"

                <div class="container mx-auto py-10">
                    <PaymentsDataTable />
                </div>
                """)
        ]
    );
}
