@using Daeha.RnUI.Demo.Wasm.Models
@using Daeha.RnUI.Demo.Wasm.BlockDemos.Sidebar.Components

@code {
    public static BlockDemo GetDemo() => new(
        Name: "Sidebar 07",
        Slug: "sidebar-07",
        Description: "A sidebar that collapses to icons with team switcher, collapsible navigation, projects, and user menu.",
        Category: "sidebar",
        Demo: @<div class="flex h-[min(600px,calc(100svh-13rem))] w-full overflow-hidden rounded-lg border border-[var(--color-border)] [transform:translateZ(0)]">
            <RnSidebarProvider>
                <AppSidebar07 />
                <RnSidebarInset>
                    <header class="flex h-16 shrink-0 items-center gap-2 transition-[width,height] ease-linear group-has-data-[collapsible=icon]/sidebar-wrapper:h-12">
                        <div class="flex items-center gap-2 px-4">
                            <RnSidebarTrigger Class="-ml-1" />
                            <RnSeparator Orientation="Orientation.Vertical" Class="mr-2 data-[orientation=vertical]:h-4" />
                            <nav aria-label="breadcrumb">
                                <ol class="flex items-center gap-1.5 text-sm text-muted-foreground">
                                    <li class="hidden md:block">
                                        <a href="#" class="transition-colors hover:text-foreground">Building Your Application</a>
                                    </li>
                                    <li role="presentation" aria-hidden="true" class="hidden md:block">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                                    </li>
                                    <li>
                                        <span role="link" aria-disabled="true" aria-current="page" class="font-normal text-foreground">Data Fetching</span>
                                    </li>
                                </ol>
                            </nav>
                        </div>
                    </header>
                    <div class="flex flex-1 flex-col gap-4 p-4 pt-0">
                        <div class="grid auto-rows-min gap-4 md:grid-cols-3">
                            <div class="aspect-video rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)]"></div>
                            <div class="aspect-video rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)]"></div>
                            <div class="aspect-video rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)]"></div>
                        </div>
                        <div class="min-h-[100vh] flex-1 rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)] md:min-h-min"></div>
                    </div>
                </RnSidebarInset>
            </RnSidebarProvider>
        </div>,
        Thumbnail: @<div class="scale-[0.4] origin-top-left pointer-events-none w-[250%] h-[300px] overflow-hidden">
            <div class="flex w-full overflow-hidden [transform:translateZ(0)]">
                <RnSidebarProvider>
                    <AppSidebar07 />
                    <RnSidebarInset>
                        <header class="flex h-16 shrink-0 items-center gap-2 px-4">
                            <RnSidebarTrigger Class="-ml-1" />
                            <RnSeparator Orientation="Orientation.Vertical" Class="mr-2 data-[orientation=vertical]:h-4" />
                            <span class="text-sm text-muted-foreground">Building Your Application</span>
                        </header>
                        <div class="flex flex-1 flex-col gap-4 p-4 pt-0">
                            <div class="grid auto-rows-min gap-4 grid-cols-3">
                                <div class="aspect-video rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)]"></div>
                                <div class="aspect-video rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)]"></div>
                                <div class="aspect-video rounded-xl bg-[color-mix(in_oklch,var(--color-muted)_50%,transparent)]"></div>
                            </div>
                        </div>
                    </RnSidebarInset>
                </RnSidebarProvider>
            </div>
        </div>,
        Files:
        [
            new("AppSidebar.razor",
                """
                <RnSidebar Collapsible="SidebarCollapsibleMode.Icon">
                    <RnSidebarHeader>
                        <TeamSwitcher />
                    </RnSidebarHeader>
                    <RnSidebarContent>
                        <NavMain Items="_navMain" />
                        <NavProjects Projects="_projects" />
                    </RnSidebarContent>
                    <RnSidebarFooter>
                        <NavUser User="_user" />
                    </RnSidebarFooter>
                    <RnSidebarRail />
                </RnSidebar>

                @code {
                    private NavItem[] _navMain = [...];
                    private ProjectItem[] _projects = [...];
                    private UserData _user = new("shadcn", "m@example.com", "/avatars/shadcn.jpg");
                }
                """),
            new("NavMain.razor",
                """
                <RnSidebarGroup>
                    <RnSidebarGroupLabel>Platform</RnSidebarGroupLabel>
                    <RnSidebarMenu>
                        @foreach (var item in Items)
                        {
                            <RnCollapsible DefaultOpen="@item.IsActive" Class="group/collapsible">
                                <Trigger>
                                    <RnSidebarMenuItem>
                                        <RnSidebarMenuButton Tooltip="@item.Title">
                                            @item.IconFragment
                                            <span>@item.Title</span>
                                            <RnIcon Icon="RnIcons.ChevronRight"
                                                    Class="ml-auto transition-transform duration-200
                                                           group-data-[state=open]/collapsible:rotate-90" />
                                        </RnSidebarMenuButton>
                                    </RnSidebarMenuItem>
                                </Trigger>
                                <ChildContent>
                                    <RnSidebarMenuSub>
                                        @if (item.SubItems is not null)
                                        {
                                            @foreach (var subItem in item.SubItems)
                                            {
                                                <RnSidebarMenuSubItem>
                                                    <RnSidebarMenuSubButton Href="@subItem.Url">
                                                        <span>@subItem.Title</span>
                                                    </RnSidebarMenuSubButton>
                                                </RnSidebarMenuSubItem>
                                            }
                                        }
                                    </RnSidebarMenuSub>
                                </ChildContent>
                            </RnCollapsible>
                        }
                    </RnSidebarMenu>
                </RnSidebarGroup>

                @code {
                    [Parameter] public NavItem[] Items { get; set; } = [];
                    public record SubItem(string Title, string Url);
                    public record NavItem(string Title, string Url, RenderFragment IconFragment,
                                          bool IsActive = false, SubItem[]? SubItems = null);
                }
                """),
            new("NavProjects.razor",
                """
                <RnSidebarGroup Class="group-data-[collapsible=icon]:hidden">
                    <RnSidebarGroupLabel>Projects</RnSidebarGroupLabel>
                    <RnSidebarMenu>
                        @foreach (var project in Projects)
                        {
                            <RnSidebarMenuItem>
                                <RnSidebarMenuButton Href="@project.Url">
                                    @project.IconFragment
                                    <span>@project.Name</span>
                                </RnSidebarMenuButton>
                                <RnDropdownMenu Side="Side.Right" Align="Alignment.Start">
                                    <Trigger>
                                        <RnSidebarMenuAction ShowOnHover>
                                            <RnIcon Icon="RnIcons.Ellipsis" />
                                            <span class="sr-only">More</span>
                                        </RnSidebarMenuAction>
                                    </Trigger>
                                    <ChildContent>
                                        <RnDropdownMenuItem>
                                            <RnIcon Icon="RnIcons.Folder" Class="text-muted-foreground" />
                                            <span>View Project</span>
                                        </RnDropdownMenuItem>
                                        <RnDropdownMenuItem>
                                            <RnIcon Icon="RnIcons.Forward" Class="text-muted-foreground" />
                                            <span>Share Project</span>
                                        </RnDropdownMenuItem>
                                        <RnDropdownMenuSeparator />
                                        <RnDropdownMenuItem>
                                            <RnIcon Icon="RnIcons.Trash2" Class="text-muted-foreground" />
                                            <span>Delete Project</span>
                                        </RnDropdownMenuItem>
                                    </ChildContent>
                                </RnDropdownMenu>
                            </RnSidebarMenuItem>
                        }
                        <RnSidebarMenuItem>
                            <RnSidebarMenuButton Class="text-sidebar-foreground/70">
                                <RnIcon Icon="RnIcons.Ellipsis" Class="text-sidebar-foreground/70" />
                                <span>More</span>
                            </RnSidebarMenuButton>
                        </RnSidebarMenuItem>
                    </RnSidebarMenu>
                </RnSidebarGroup>

                @code {
                    [Parameter] public ProjectItem[] Projects { get; set; } = [];
                    public record ProjectItem(string Name, string Url, RenderFragment IconFragment);
                }
                """),
            new("NavUser.razor",
                """
                <RnSidebarMenu>
                    <RnSidebarMenuItem>
                        <RnDropdownMenu Side="Side.Top" Align="Alignment.End">
                            <Trigger>
                                <RnSidebarMenuButton Size="SidebarMenuButtonSize.Lg"
                                    Class="data-[state=open]:bg-sidebar-accent
                                           data-[state=open]:text-sidebar-accent-foreground">
                                    <RnAvatar Src="@User.Avatar" Alt="@User.Name" Class="h-8 w-8 rounded-lg">
                                        <RnAvatarFallback Class="rounded-lg">CN</RnAvatarFallback>
                                    </RnAvatar>
                                    <div class="grid flex-1 text-left text-sm leading-tight">
                                        <span class="truncate font-medium">@User.Name</span>
                                        <span class="truncate text-xs">@User.Email</span>
                                    </div>
                                    <RnIcon Icon="RnIcons.ChevronsUpDown" Class="ml-auto size-4" />
                                </RnSidebarMenuButton>
                            </Trigger>
                            <ChildContent>
                                <RnDropdownMenuLabel Class="p-0 font-normal">
                                    <div class="flex items-center gap-2 px-1 py-1.5 text-left text-sm">
                                        <RnAvatar Src="@User.Avatar" Alt="@User.Name" Class="h-8 w-8 rounded-lg">
                                            <RnAvatarFallback Class="rounded-lg">CN</RnAvatarFallback>
                                        </RnAvatar>
                                        <div class="grid flex-1 text-left text-sm leading-tight">
                                            <span class="truncate font-medium">@User.Name</span>
                                            <span class="truncate text-xs">@User.Email</span>
                                        </div>
                                    </div>
                                </RnDropdownMenuLabel>
                                <RnDropdownMenuSeparator />
                                <RnDropdownMenuGroup>
                                    <RnDropdownMenuItem>
                                        <RnIcon Icon="RnIcons.Sparkles" /> Upgrade to Pro
                                    </RnDropdownMenuItem>
                                </RnDropdownMenuGroup>
                                <RnDropdownMenuSeparator />
                                <RnDropdownMenuGroup>
                                    <RnDropdownMenuItem>
                                        <RnIcon Icon="RnIcons.BadgeCheck" /> Account
                                    </RnDropdownMenuItem>
                                    <RnDropdownMenuItem>
                                        <RnIcon Icon="RnIcons.CreditCard" /> Billing
                                    </RnDropdownMenuItem>
                                    <RnDropdownMenuItem>
                                        <RnIcon Icon="RnIcons.Bell" /> Notifications
                                    </RnDropdownMenuItem>
                                </RnDropdownMenuGroup>
                                <RnDropdownMenuSeparator />
                                <RnDropdownMenuItem>
                                    <RnIcon Icon="RnIcons.LogOut" /> Log out
                                </RnDropdownMenuItem>
                            </ChildContent>
                        </RnDropdownMenu>
                    </RnSidebarMenuItem>
                </RnSidebarMenu>

                @code {
                    [Parameter] public UserData User { get; set; } = default!;
                    public record UserData(string Name, string Email, string Avatar);
                }
                """),
            new("TeamSwitcher.razor",
                """
                <RnSidebarMenu>
                    <RnSidebarMenuItem>
                        <RnDropdownMenu Side="Side.Bottom" Align="Alignment.Start">
                            <Trigger>
                                <RnSidebarMenuButton Size="SidebarMenuButtonSize.Lg"
                                    Class="data-[state=open]:bg-sidebar-accent
                                           data-[state=open]:text-sidebar-accent-foreground">
                                    <div class="flex aspect-square size-8 items-center justify-center
                                                rounded-lg bg-sidebar-primary text-sidebar-primary-foreground">
                                        @_activeTeam.LogoFragment
                                    </div>
                                    <div class="grid flex-1 text-left text-sm leading-tight">
                                        <span class="truncate font-medium">@_activeTeam.Name</span>
                                        <span class="truncate text-xs">@_activeTeam.Plan</span>
                                    </div>
                                    <RnIcon Icon="RnIcons.ChevronsUpDown" Class="ml-auto" />
                                </RnSidebarMenuButton>
                            </Trigger>
                            <ChildContent>
                                <RnDropdownMenuLabel Class="text-xs text-muted-foreground">
                                    Teams
                                </RnDropdownMenuLabel>
                                @for (var i = 0; i < _teams.Length; i++)
                                {
                                    var team = _teams[i];
                                    var index = i + 1;
                                    <RnDropdownMenuItem OnClick="() => _activeTeam = team" Class="gap-2 p-2">
                                        <div class="flex size-6 items-center justify-center rounded-md border">
                                            @team.LogoFragment
                                        </div>
                                        @team.Name
                                        <RnDropdownMenuShortcut>⌘@index</RnDropdownMenuShortcut>
                                    </RnDropdownMenuItem>
                                }
                                <RnDropdownMenuSeparator />
                                <RnDropdownMenuItem Class="gap-2 p-2">
                                    <div class="flex size-6 items-center justify-center rounded-md border bg-transparent">
                                        <RnIcon Icon="RnIcons.Plus" />
                                    </div>
                                    <div class="font-medium text-muted-foreground">Add team</div>
                                </RnDropdownMenuItem>
                            </ChildContent>
                        </RnDropdownMenu>
                    </RnSidebarMenuItem>
                </RnSidebarMenu>

                @code {
                    private record TeamData(string Name, string Plan, RenderFragment LogoFragment);
                    private TeamData[] _teams = [...];
                    private TeamData _activeTeam = default!;
                }
                """),
            new("Page.razor",
                """
                <RnSidebarProvider>
                    <AppSidebar />
                    <RnSidebarInset>
                        <header class="flex h-16 shrink-0 items-center gap-2
                                       transition-[width,height] ease-linear
                                       group-has-data-[collapsible=icon]/sidebar-wrapper:h-12">
                            <div class="flex items-center gap-2 px-4">
                                <RnSidebarTrigger Class="-ml-1" />
                                <RnSeparator Orientation="Orientation.Vertical"
                                             Class="mr-2 data-[orientation=vertical]:h-4" />
                                <RnBreadcrumb>
                                    <RnBreadcrumbList>
                                        <RnBreadcrumbItem>
                                            <RnBreadcrumbLink Href="#">
                                                Building Your Application
                                            </RnBreadcrumbLink>
                                        </RnBreadcrumbItem>
                                        <RnBreadcrumbSeparator />
                                        <RnBreadcrumbItem>
                                            <RnBreadcrumbPage>Data Fetching</RnBreadcrumbPage>
                                        </RnBreadcrumbItem>
                                    </RnBreadcrumbList>
                                </RnBreadcrumb>
                            </div>
                        </header>
                        <div class="flex flex-1 flex-col gap-4 p-4 pt-0">
                            @* Your content here *@
                        </div>
                    </RnSidebarInset>
                </RnSidebarProvider>
                """)
        ]
    );
}
