@* NavProjects component for sidebar-07 block *@

<RnSidebarGroup Class="group-data-[collapsible=icon]:hidden">
    <RnSidebarGroupLabel>Projects</RnSidebarGroupLabel>
    <RnSidebarMenu>
        @foreach (var project in Projects)
        {
            <RnSidebarMenuItem>
                <RnSidebarMenuButton Href="@project.Url">
                    @project.IconFragment
                    <span>@project.Name</span>
                </RnSidebarMenuButton>
                <RnDropdownMenu Side="Side.Right" Align="Alignment.Start">
                    <Trigger>
                        <RnSidebarMenuAction ShowOnHover>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="1"/>
                                <circle cx="19" cy="12" r="1"/>
                                <circle cx="5" cy="12" r="1"/>
                            </svg>
                            <span class="sr-only">More</span>
                        </RnSidebarMenuAction>
                    </Trigger>
                    <ChildContent>
                        <RnDropdownMenuItem>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                 class="text-muted-foreground">
                                <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
                            </svg>
                            <span>View Project</span>
                        </RnDropdownMenuItem>
                        <RnDropdownMenuItem>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                 class="text-muted-foreground">
                                <polyline points="15 17 20 12 15 7"/>
                                <path d="M4 18v-2a4 4 0 0 1 4-4h12"/>
                            </svg>
                            <span>Share Project</span>
                        </RnDropdownMenuItem>
                        <RnDropdownMenuSeparator />
                        <RnDropdownMenuItem>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                 class="text-muted-foreground">
                                <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                            </svg>
                            <span>Delete Project</span>
                        </RnDropdownMenuItem>
                    </ChildContent>
                </RnDropdownMenu>
            </RnSidebarMenuItem>
        }
        <RnSidebarMenuItem>
            <RnSidebarMenuButton Class="text-sidebar-foreground/70">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     class="text-sidebar-foreground/70">
                    <circle cx="12" cy="12" r="1"/>
                    <circle cx="19" cy="12" r="1"/>
                    <circle cx="5" cy="12" r="1"/>
                </svg>
                <span>More</span>
            </RnSidebarMenuButton>
        </RnSidebarMenuItem>
    </RnSidebarMenu>
</RnSidebarGroup>

@code {
    [Parameter] public ProjectItem[] Projects { get; set; } = [];

    public record ProjectItem(string Name, string Url, RenderFragment IconFragment);
}
