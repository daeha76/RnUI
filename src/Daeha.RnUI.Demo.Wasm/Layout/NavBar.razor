@inject NavigationManager Navigation

<nav class="flex flex-1 items-center space-x-4 lg:space-x-6">
    <a href="/" class="flex items-center space-x-2 mr-6">
        <span class="font-bold text-lg">RnUI</span>
    </a>
    <div class="flex items-center space-x-4 text-sm font-medium">
        <a href="/docs/getting-started"
           class="transition-colors hover:text-foreground/80 @(IsActive("/docs") ? "text-foreground" : "text-foreground/60")">
            Docs
        </a>
        <a href="/components"
           class="transition-colors hover:text-foreground/80 @(IsActive("/components") ? "text-foreground" : "text-foreground/60")">
            Components
        </a>
        <a href="https://github.com/daeha76/RnUI" target="_blank"
           class="transition-colors hover:text-foreground/80 text-foreground/60">
            GitHub
        </a>
    </div>
    <div class="flex flex-1 items-center justify-end">
        <ThemeToggle />
    </div>
</nav>

@code {
    private bool IsActive(string prefix)
        => Navigation.Uri.Contains(prefix, StringComparison.OrdinalIgnoreCase);
}
