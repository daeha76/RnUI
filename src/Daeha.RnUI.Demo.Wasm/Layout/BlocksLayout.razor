@inherits LayoutComponentBase

<div class="relative flex min-h-screen flex-col bg-background text-foreground">
    <header class="w-full border-b border-[var(--color-border-subtle)] bg-background">
        <div class="container flex h-14 max-w-screen-2xl items-center">
            <NavBar />
        </div>
    </header>
    <main class="container flex-1 items-start md:grid md:grid-cols-[220px_minmax(0,1fr)] md:gap-6 lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-10">
        <aside class="fixed top-14 z-30 -ml-2 hidden h-[calc(100vh-3.5rem)] w-full shrink-0 md:sticky md:block">
            <div class="h-full overflow-y-auto py-6 pr-6 lg:py-8">
                <DocsSidebar />
            </div>
        </aside>
        <div class="container max-w-screen-2xl py-6">
            @Body
        </div>
    </main>
    <RnToastProvider />
</div>
