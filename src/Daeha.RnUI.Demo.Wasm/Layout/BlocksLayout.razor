@inherits LayoutComponentBase

<div class="relative flex min-h-screen flex-col bg-background text-foreground">
    <header class="w-full border-b border-[var(--color-border-subtle)] bg-background">
        <div class="flex h-14 items-center px-4 md:px-8">
            <NavBar />
        </div>
    </header>
    <div class="w-full px-4 md:px-8 flex-1 items-start md:grid md:grid-cols-[220px_minmax(0,1fr)] md:gap-6 lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-10">
        <aside class="fixed top-14 z-30 -ml-2 hidden h-[calc(100vh-3.5rem)] w-full shrink-0 md:sticky md:block">
            <div id="docs-sidebar-scroll" class="h-full overflow-y-auto py-6 pr-6 lg:py-8">
                <DocsSidebar />
            </div>
        </aside>
        <main class="w-full min-w-0 py-6">
            @Body
        </main>
    </div>
    <RnToastProvider />
</div>
