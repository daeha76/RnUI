@inherits LayoutComponentBase

<div class="relative flex min-h-screen flex-col">
    <header class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
        <div class="container flex h-14 max-w-screen-2xl items-center px-4">
            <a href="/" class="flex items-center space-x-2 font-bold mr-6">
                <span>RnUI</span>
            </a>
            <nav class="hidden md:flex md:items-center md:space-x-4">
                <a href="/" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">Home</a>
                <a href="/components" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">Components</a>
            </nav>
        </div>
    </header>
    <main class="flex-1">
        <div class="container py-6 px-4">
            @Body
        </div>
    </main>
    <footer class="border-t border-border/40 py-6">
        <div class="container flex items-center justify-center px-4">
            <p class="text-sm text-muted-foreground">
                Built with <a href="https://github.com/daeha76/RnUI" class="font-medium underline underline-offset-4 hover:text-foreground" target="_blank">RnUI</a> — A Blazor port of shadcn/ui.
            </p>
        </div>
    </footer>
</div>
