@inject IJSRuntime JS

<div class="relative my-4 overflow-hidden rounded-xl border border-[var(--color-border-subtle)]">
    @if (!string.IsNullOrEmpty(FileName))
    {
        <div class="flex items-center border-b border-white/5 bg-zinc-900 px-4 py-2">
            <span class="text-xs font-medium text-zinc-400">@FileName</span>
        </div>
    }
    <button class="absolute right-3 @(string.IsNullOrEmpty(FileName) ? "top-3" : "top-11") z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-white/10 bg-white/5 text-zinc-400 hover:bg-white/10 hover:text-zinc-200 transition-colors"
            @onclick="CopyCode"
            title="Copy code">
        @if (_copied)
        {
            <RnIcon Icon="RnIcons.Check" Size="14" />
        }
        else
        {
            <RnIcon Icon="RnIcons.Copy" Size="14" />
        }
    </button>
    <div class="overflow-x-auto bg-zinc-950">
        <pre class="p-4 text-sm leading-relaxed text-zinc-300"><code class="font-mono">@SyntaxHighlighter.HighlightXml(Code)</code></pre>
    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";
    [Parameter] public string? FileName { get; set; }

    private bool _copied;

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(Code)) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Code);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }
}
