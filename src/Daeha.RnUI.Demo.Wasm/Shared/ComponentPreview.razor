@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components

<div class="group relative my-4 flex flex-col overflow-hidden rounded-xl border border-[var(--color-border-subtle)]">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="px-4 py-3 border-b border-[var(--color-border-subtle)]">
            <h3 class="text-sm font-medium">@Title</h3>
        </div>
    }
    <div class="preview-area flex min-h-[350px] items-center justify-center p-10">
        @ChildContent
    </div>
    @if (!string.IsNullOrEmpty(Code))
    {
        <div class="relative border-t border-[var(--color-border-subtle)]">
            <button class="absolute right-3 top-3 z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-white/10 bg-white/5 text-zinc-400 hover:bg-white/10 hover:text-zinc-200 transition-colors"
                    @onclick="CopyCode"
                    title="Copy code">
                @if (_copied)
                {
                    <RnIcon Icon="RnIcons.Check" Size="14" />
                }
                else
                {
                    <RnIcon Icon="RnIcons.Copy" Size="14" />
                }
            </button>
            <div class="code-block overflow-x-auto bg-zinc-950 @(_expanded ? "" : "max-h-[120px] overflow-hidden")">
                <pre class="p-4 text-sm leading-relaxed text-zinc-300"><code class="font-mono">@SyntaxHighlighter.HighlightXml(Code)</code></pre>
            </div>
            @if (!_expanded && Code.Split('\n').Length > 4)
            {
                <div class="absolute bottom-0 left-0 right-0 flex items-end justify-center bg-gradient-to-t from-zinc-950 via-zinc-950/80 to-transparent pb-2 pt-8">
                    <button class="inline-flex items-center gap-1 rounded-md border border-white/10 bg-zinc-900 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-800 hover:text-zinc-100 transition-colors"
                            @onclick="() => _expanded = true">
                        View Code
                        <RnIcon Icon="RnIcons.ChevronDown" Size="12" />
                    </button>
                </div>
            }
            @if (_expanded && Code.Split('\n').Length > 4)
            {
                <div class="flex justify-center border-t border-white/5 bg-zinc-950 py-2">
                    <button class="inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 transition-colors"
                            @onclick="() => _expanded = false">
                        Collapse
                        <RnIcon Icon="RnIcons.ChevronUp" Size="12" />
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Code { get; set; }
    [Parameter] public string? Title { get; set; }

    private bool _expanded;
    private bool _copied;

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(Code)) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Code);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }
}
