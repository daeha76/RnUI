@page "/components"
@page "/components/{Slug}"

<PageTitle>@(_currentComponent?.Name ?? "Components") - RnUI</PageTitle>

@if (string.IsNullOrEmpty(Slug))
{
    <div class="space-y-6">
        <div>
            <h1 class="scroll-m-20 text-3xl font-semibold tracking-tight">Components</h1>
            <p class="text-base text-muted-foreground leading-relaxed">
                Beautifully designed components built with Tailwind CSS for Blazor.
            </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var component in _componentDemos)
            {
                <a href="components/@component.Slug" class="group block">
                    <div class="rounded-xl border border-[var(--color-border-subtle)] bg-card transition-colors hover:border-foreground/30">
                        <div class="flex h-[140px] items-center justify-center border-b border-[var(--color-border-subtle)] p-4">
                            <div class="scale-[0.8] pointer-events-none">
                                @component.Thumbnail
                            </div>
                        </div>
                        <div class="p-4">
                            <h3 class="text-sm font-medium">@component.Name</h3>
                            <p class="text-xs text-muted-foreground mt-1 line-clamp-1">@component.Description</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
}
else if (_currentComponent is not null)
{
    <div class="space-y-8">
        <div>
            <h1 class="scroll-m-20 text-3xl font-semibold tracking-tight">@_currentComponent.Name</h1>
            <p class="text-base text-muted-foreground leading-relaxed mt-1.5">@_currentComponent.Description</p>
        </div>

        <ComponentPreview Code="@_currentComponent.Code">
            @_currentComponent.Demo
        </ComponentPreview>

        <div class="space-y-4">
            <h2 class="scroll-m-20 border-b border-[var(--color-border-subtle)] pb-2 text-xl font-medium tracking-tight">Usage</h2>
            <CodeBlock Code="@_currentComponent.UsageCode" FileName="MyPage.razor" />
        </div>

        @if (_currentComponent.Examples is not null)
        {
            <div class="space-y-6">
                <h2 class="scroll-m-20 border-b border-[var(--color-border-subtle)] pb-2 text-xl font-medium tracking-tight">Examples</h2>
                @foreach (var example in _currentComponent.Examples)
                {
                    <div class="space-y-2">
                        <h3 class="text-base font-medium">@example.Title</h3>
                        @if (!string.IsNullOrEmpty(example.Description))
                        {
                            <p class="text-sm text-muted-foreground">@example.Description</p>
                        }
                        <ComponentPreview Code="@example.Code" Title="@example.Title">
                            @example.Demo
                        </ComponentPreview>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="space-y-4">
        <h1 class="text-3xl font-semibold tracking-tight">Component not found</h1>
        <p class="text-muted-foreground">The component "@Slug" does not exist.</p>
        <RnButton OnClick="@(() => Navigation.NavigateTo("components"))">Back to Components</RnButton>
    </div>
}

