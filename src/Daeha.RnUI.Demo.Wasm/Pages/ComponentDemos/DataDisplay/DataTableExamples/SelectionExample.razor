@* Selection Example - Multiple selection with Shift+click range select *@

<RnDataTable TItem="TaskItem" Items="_tasks" SelectionMode="SelectionMode.Multiple"
             @bind-SelectedItems="_selected" PageSize="5" ShowPagination="false">
    <Columns>
        <RnDataTableColumn TItem="TaskItem" Property="x => x.Title" Title="Task" Sortable />
        <RnDataTableColumn TItem="TaskItem" Property="x => x.Priority" Title="Priority" Sortable Filterable>
            <CellTemplate Context="item">
                <RnBadge Variant="@GetPriorityVariant(item.Priority)">@item.Priority</RnBadge>
            </CellTemplate>
        </RnDataTableColumn>
        <RnDataTableColumn TItem="TaskItem" Property="x => x.Assignee" Title="Assignee" />
    </Columns>
</RnDataTable>

@if (_selected.Count > 0)
{
    <p class="text-sm mt-2">Selected: <strong>@_selected.Count</strong> task(s) — @string.Join(", ", _selected.Select(t => t.Title))</p>
}

@code {
    private record TaskItem(string Title, string Priority, string Assignee);

    private HashSet<TaskItem> _selected = [];

    private readonly List<TaskItem> _tasks =
    [
        new("Fix login bug", "High", "Alice"),
        new("Update docs", "Low", "Bob"),
        new("Add dark mode", "Medium", "Charlie"),
        new("Optimize queries", "High", "Diana"),
        new("Write tests", "Medium", "Eve"),
    ];

    private static BadgeVariant GetPriorityVariant(string priority) => priority switch
    {
        "High" => BadgeVariant.Destructive,
        "Medium" => BadgeVariant.Default,
        "Low" => BadgeVariant.Secondary,
        _ => BadgeVariant.Outline
    };
}
