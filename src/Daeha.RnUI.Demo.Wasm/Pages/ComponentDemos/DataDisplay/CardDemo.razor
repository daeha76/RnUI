@using Daeha.RnUI.Demo.Wasm.Models

@code {
    public static ComponentDemo GetDemo() => new(
        "Card", "card", "Displays a card with header, content, and footer.",
        Demo: @<div class="w-full max-w-sm">
            <RnCard>
                <RnCardHeader>
                    <RnCardTitle>Notifications</RnCardTitle>
                    <RnCardDescription>You have 3 unread messages.</RnCardDescription>
                </RnCardHeader>
                <RnCardContent class="grid gap-4">
                    <div class="flex items-center gap-4 rounded-md border border-[var(--color-border-subtle)] p-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
                        <div class="flex-1 space-y-1">
                            <p class="text-sm font-medium leading-none">Push Notifications</p>
                            <p class="text-sm text-muted-foreground">Send notifications to device.</p>
                        </div>
                        <RnSwitch />
                    </div>
                </RnCardContent>
                <RnCardFooter>
                    <RnButton Class="w-full">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        Mark all as read
                    </RnButton>
                </RnCardFooter>
            </RnCard>
        </div>,
        Thumbnail: @<div class="w-[180px]">
            <RnCard>
                <RnCardHeader>
                    <RnCardTitle>Card</RnCardTitle>
                    <RnCardDescription>Description</RnCardDescription>
                </RnCardHeader>
            </RnCard>
        </div>,
        Code: @"<RnCard>
    <RnCardHeader>
        <RnCardTitle>Notifications</RnCardTitle>
        <RnCardDescription>You have 3 unread messages.</RnCardDescription>
    </RnCardHeader>
    <RnCardContent>
        <div class=""flex items-center gap-4 rounded-md border p-4"">
            <div class=""flex-1 space-y-1"">
                <p class=""text-sm font-medium leading-none"">Push Notifications</p>
                <p class=""text-sm text-muted-foreground"">Send notifications to device.</p>
            </div>
            <RnSwitch />
        </div>
    </RnCardContent>
    <RnCardFooter>
        <RnButton Class=""w-full"">Mark all as read</RnButton>
    </RnCardFooter>
</RnCard>",
        UsageCode: @"@using RnUI.Components.UI.Card

<RnCard>
    <RnCardHeader>
        <RnCardTitle>Title</RnCardTitle>
        <RnCardDescription>Description</RnCardDescription>
    </RnCardHeader>
    <RnCardContent>Content</RnCardContent>
    <RnCardFooter>Footer</RnCardFooter>
</RnCard>"
    );
}
