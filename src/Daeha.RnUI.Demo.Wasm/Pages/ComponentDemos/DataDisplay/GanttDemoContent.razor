<div class="flex flex-col gap-4">
    <div class="flex items-center gap-2 flex-wrap">
        <span class="text-sm font-medium text-muted-foreground">View:</span>
        @foreach (var mode in Enum.GetValues<GanttViewMode>())
        {
            <RnButton Variant="@(_viewMode == mode ? ButtonVariant.Default : ButtonVariant.Outline)"
                      Size="ButtonSize.Sm"
                      OnClick="@(() => SetViewMode(mode))">
                @mode.ToString()
            </RnButton>
        }
        <div class="h-6 w-px bg-border mx-1"></div>
        <span class="text-sm font-medium text-muted-foreground">Zoom:</span>
        <RnButton Variant="ButtonVariant.Outline" Size="ButtonSize.Sm"
                  OnClick="ZoomOut">-</RnButton>
        <RnButton Variant="ButtonVariant.Outline" Size="ButtonSize.Sm"
                  OnClick="ZoomIn">+</RnButton>
    </div>

    <div style="height: 500px;">
        <RnGantt @ref="_gantt"
                 Rows="_rows"
                 ViewMode="_viewMode"
                 Today="DateTime.Today"
                 ShowTodayMarker="true"
                 ShowLegend="true"
                 LegendItems="_legendItems"
                 OnBarClick="HandleBarClick"
                 Class="h-full" />
    </div>

    @if (_selectedTask != null)
    {
        <div class="p-3 rounded-lg bg-muted text-sm">
            <span class="font-medium">Selected:</span> @_selectedTask.Label
            (@_selectedTask.StartDate.ToString("yyyy-MM-dd") ~ @_selectedTask.EndDate.ToString("yyyy-MM-dd"))
        </div>
    }
</div>

@code {
    private RnGantt _gantt = default!;
    private GanttViewMode _viewMode = GanttViewMode.Month;
    private GanttTask? _selectedTask;

    private void SetViewMode(GanttViewMode mode)
    {
        _viewMode = mode;
    }

    private void ZoomIn() => _gantt.ZoomIn();
