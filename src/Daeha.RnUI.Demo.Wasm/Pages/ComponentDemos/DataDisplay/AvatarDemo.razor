@using Daeha.RnUI.Demo.Wasm.Models

@code {
    public static ComponentDemo GetDemo() => new(
        "Avatar", "avatar", "An image element with a fallback for representing the user.",
        Demo: @<div class="space-y-6">
            <div class="space-y-2">
                <p class="text-sm font-medium">Sizes</p>
                <div class="flex items-center gap-4">
                    <RnAvatar Size="ComponentSize.Sm"><span>SM</span></RnAvatar>
                    <RnAvatar Src="https://github.com/shadcn.png" Alt="shadcn" />
                    <RnAvatar Size="ComponentSize.Lg"><span>LG</span></RnAvatar>
                </div>
            </div>
            <div class="space-y-2">
                <p class="text-sm font-medium">Group</p>
                <RnAvatarGroup>
                    <RnAvatar><span>A</span></RnAvatar>
                    <RnAvatar><span>B</span></RnAvatar>
                    <RnAvatar><span>C</span></RnAvatar>
                    <RnAvatar><span>+2</span></RnAvatar>
                </RnAvatarGroup>
            </div>
        </div>,
        Thumbnail: @<div class="flex gap-2">
            <RnAvatar Size="ComponentSize.Sm"><span>CN</span></RnAvatar>
            <RnAvatar Size="ComponentSize.Sm"><span>AB</span></RnAvatar>
        </div>,
        Code: @"<RnAvatar Src=""https://github.com/shadcn.png""
         Alt=""shadcn"" />

<RnAvatar Size=""ComponentSize.Sm"">
    <span>CN</span>
</RnAvatar>

<RnAvatarGroup>
    <RnAvatar><span>A</span></RnAvatar>
    <RnAvatar><span>B</span></RnAvatar>
    <RnAvatar><span>C</span></RnAvatar>
    <RnAvatar><span>+2</span></RnAvatar>
</RnAvatarGroup>",
        UsageCode: @"@using RnUI.Components.UI.Avatar

<RnAvatar Src=""avatar.png"" Alt=""User"" />
<RnAvatar><span>CN</span></RnAvatar>"
    );
}
