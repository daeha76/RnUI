@using Daeha.RnUI.Demo.Wasm.Models

@code {
    public static ComponentDemo GetDemo() => new(
        "Badge", "badge", "Displays a badge or a component that looks like a badge.",
        Demo: @<div class="flex flex-col items-center gap-2">
            <div class="flex w-full flex-wrap gap-2">
                <RnBadge>Badge</RnBadge>
                <RnBadge Variant="BadgeVariant.Secondary">Secondary</RnBadge>
                <RnBadge Variant="BadgeVariant.Destructive">Destructive</RnBadge>
                <RnBadge Variant="BadgeVariant.Outline">Outline</RnBadge>
            </div>
            <div class="flex w-full flex-wrap gap-2">
