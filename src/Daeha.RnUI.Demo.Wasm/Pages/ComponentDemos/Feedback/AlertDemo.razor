@using Daeha.RnUI.Demo.Wasm.Models

@code {
    public static ComponentDemo GetDemo() => new(
        "Alert", "alert", "Displays a callout for important information.",
        Demo: @<div class="w-full max-w-lg space-y-4">
            <RnAlert>
                <Icon>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
                </Icon>
                <ChildContent>
                    <RnAlertTitle>Heads up!</RnAlertTitle>
                    <RnAlertDescription>You can add components to your app using the CLI.</RnAlertDescription>
                </ChildContent>
            </RnAlert>
            <RnAlert Variant="AlertVariant.Destructive">
                <Icon>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                </Icon>
                <ChildContent>
                    <RnAlertTitle>Error</RnAlertTitle>
                    <RnAlertDescription>Your session has expired. Please log in again.</RnAlertDescription>
                </ChildContent>
            </RnAlert>
        </div>,
        Thumbnail: @<div class="w-[200px]">
            <RnAlert>
                <RnAlertTitle>Heads up!</RnAlertTitle>
                <RnAlertDescription>Important info.</RnAlertDescription>
            </RnAlert>
        </div>,
        Code: @"<RnAlert>
    <Icon>
        <svg><!-- lightbulb icon --></svg>
    </Icon>
    <ChildContent>
        <RnAlertTitle>Heads up!</RnAlertTitle>
        <RnAlertDescription>
            You can add components to your app using the CLI.
        </RnAlertDescription>
    </ChildContent>
</RnAlert>

<RnAlert Variant=""AlertVariant.Destructive"">
    <Icon>
        <svg><!-- alert icon --></svg>
    </Icon>
    <ChildContent>
        <RnAlertTitle>Error</RnAlertTitle>
        <RnAlertDescription>Your session has expired.</RnAlertDescription>
    </ChildContent>
</RnAlert>",
        UsageCode: @"@using RnUI.Components.UI.Alert

<RnAlert>
    <Icon><MyIcon /></Icon>
    <ChildContent>
        <RnAlertTitle>Title</RnAlertTitle>
        <RnAlertDescription>Description</RnAlertDescription>
    </ChildContent>
</RnAlert>"
    );
}
