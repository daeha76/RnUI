@using Daeha.RnUI.Demo.Wasm.Models

@code {
    public static ComponentDemo GetDemo() => new(
        "Toggle", "toggle", "A two-state button that can be either on or off.",
        Demo: @<div class="flex flex-col gap-4">
                <div class="flex items-center gap-2">
                    <RnToggle aria-label="Toggle bold">
                        <RnIcon Icon="RnIcons.Bold" Size="16" />
                    </RnToggle>
                    <RnToggle Variant="ToggleVariant.Outline" aria-label="Toggle italic">
                        <RnIcon Icon="RnIcons.Italic" Size="16" />
                    </RnToggle>
                    <RnToggle Disabled="true" aria-label="Toggle underline">
                        <RnIcon Icon="RnIcons.Underline" Size="16" />
                    </RnToggle>
                </div>
            </div>,
        Thumbnail: @<RnToggle aria-label="Toggle bold" Size="ToggleSize.Sm">
                <RnIcon Icon="RnIcons.Bold" Size="14" />
            </RnToggle>,
        Code: @"<RnToggle aria-label=""Toggle bold"">
    <svg><!-- bold icon --></svg>
</RnToggle>
<RnToggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle italic"">
    <svg><!-- italic icon --></svg>
</RnToggle>
<RnToggle Disabled=""true"" aria-label=""Toggle underline"">
    <svg><!-- underline icon --></svg>
</RnToggle>",
        UsageCode: @"@using RnUI.Components.UI.Toggle

<RnToggle aria-label=""Toggle bold"">
    <svg>...</svg>
</RnToggle>"
    );
}
