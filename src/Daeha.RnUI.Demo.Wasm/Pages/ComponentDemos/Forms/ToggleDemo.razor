            </RnToggle>,
        Code: @"<RnToggle aria-label=""Toggle bold"">
    <svg><!-- bold icon --></svg>
</RnToggle>
<RnToggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle italic"">
    <svg><!-- italic icon --></svg>
</RnToggle>
<RnToggle Disabled=""true"" aria-label=""Toggle underline"">
    <svg><!-- underline icon --></svg>
</RnToggle>",
        UsageCode: @"@using RnUI.Components.UI.Toggle

<RnToggle aria-label=""Toggle bold"">
    <svg>...</svg>
</RnToggle>"
    );
}
