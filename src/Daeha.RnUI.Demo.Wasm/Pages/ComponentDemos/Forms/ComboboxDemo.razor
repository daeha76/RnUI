    <RnComboboxItem Value=""astro"" Label=""Astro"">Astro</RnComboboxItem>
</RnCombobox>

@code {
    private string? _value;
}",
        UsageCode: @"@using RnUI.Components.UI.Combobox

<RnCombobox @bind-Value=""_value"" Placeholder=""Select..."">
    <RnComboboxItem Value=""a"" Label=""Option A"">Option A</RnComboboxItem>
    <RnComboboxItem Value=""b"" Label=""Option B"">Option B</RnComboboxItem>
</RnCombobox>

@code {
