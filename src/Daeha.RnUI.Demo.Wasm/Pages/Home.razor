@page "/"

<PageTitle>RnUI - Blazor Component Library</PageTitle>

<div class="space-y-16">
    <div class="flex flex-col items-center text-center space-y-4 pt-12 pb-8">
        <RnBadge Variant="BadgeVariant.Secondary" Class="mb-2">Open Source</RnBadge>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">
            Build your Blazor UI
            <br />
            <span class="text-primary">with shadcn/ui style</span>
        </h1>
        <p class="text-lg text-muted-foreground max-w-[600px] leading-relaxed">
            Beautifully designed, accessible components for Blazor.
            Built with Tailwind CSS. Open source.
        </p>
        <div class="flex gap-4 pt-4 flex-wrap justify-center">
            <a href="/components" class="cn-button cn-button-variant-default cn-button-size-lg">Browse Components</a>
            <a href="https://github.com/daeha76/RnUI" target="_blank" class="cn-button cn-button-variant-outline cn-button-size-lg">GitHub</a>
        </div>
    </div>

    <div class="space-y-12">
        <section class="space-y-4">
            <div>
                <h2 class="text-2xl font-semibold tracking-tight">Button</h2>
                <p class="text-sm text-muted-foreground">Displays a button or a component that looks like a button.</p>
            </div>
            <ComponentPreview Code="@_buttonCode">
                <div class="flex flex-wrap gap-4">
                    <RnButton>Default</RnButton>
                    <RnButton Variant="ButtonVariant.Secondary">Secondary</RnButton>
                    <RnButton Variant="ButtonVariant.Outline">Outline</RnButton>
                    <RnButton Variant="ButtonVariant.Ghost">Ghost</RnButton>
                    <RnButton Variant="ButtonVariant.Destructive">Destructive</RnButton>
                    <RnButton Variant="ButtonVariant.Link">Link</RnButton>
                </div>
            </ComponentPreview>
        </section>

        <section class="space-y-4">
            <div>
                <h2 class="text-2xl font-semibold tracking-tight">Card</h2>
                <p class="text-sm text-muted-foreground">Displays a card with header, content, and footer.</p>
            </div>
            <ComponentPreview Code="@_cardCode">
                <div class="w-full max-w-sm">
                    <RnCard>
                        <RnCardHeader>
                            <RnCardTitle>Card Title</RnCardTitle>
                            <RnCardDescription>Card description goes here.</RnCardDescription>
                        </RnCardHeader>
                        <RnCardContent>
                            <div class="space-y-2">
                                <RnLabel>Name</RnLabel>
                                <RnInput Placeholder="Your name" />
                            </div>
                        </RnCardContent>
                        <RnCardFooter Class="flex justify-between">
                            <RnButton Variant="ButtonVariant.Outline">Cancel</RnButton>
                            <RnButton>Deploy</RnButton>
                        </RnCardFooter>
                    </RnCard>
                </div>
            </ComponentPreview>
        </section>

        <section class="space-y-4">
            <div>
                <h2 class="text-2xl font-semibold tracking-tight">Tabs</h2>
                <p class="text-sm text-muted-foreground">A set of layered sections of content, shown one at a time.</p>
            </div>
            <ComponentPreview Code="@_tabsCode">
                <div class="w-full max-w-md">
                    <RnTabs @bind-ActiveTab="_activeTab">
                        <RnTabsList>
                            <RnTabsTrigger Value="account">Account</RnTabsTrigger>
                            <RnTabsTrigger Value="password">Password</RnTabsTrigger>
                        </RnTabsList>
                        <RnTabsContent Value="account">
                            <RnCard>
                                <RnCardHeader>
                                    <RnCardTitle>Account</RnCardTitle>
                                    <RnCardDescription>Make changes to your account here.</RnCardDescription>
                                </RnCardHeader>
                                <RnCardContent>
                                    <div class="space-y-2">
                                        <RnLabel>Name</RnLabel>
                                        <RnInput Placeholder="Your name" />
                                    </div>
                                </RnCardContent>
                            </RnCard>
                        </RnTabsContent>
                        <RnTabsContent Value="password">
                            <RnCard>
                                <RnCardHeader>
                                    <RnCardTitle>Password</RnCardTitle>
                                    <RnCardDescription>Change your password here.</RnCardDescription>
                                </RnCardHeader>
                                <RnCardContent>
                                    <div class="space-y-2">
                                        <RnLabel>New Password</RnLabel>
                                        <RnInput Type="password" />
                                    </div>
                                </RnCardContent>
                            </RnCard>
                        </RnTabsContent>
                    </RnTabs>
                </div>
            </ComponentPreview>
        </section>

        <section class="space-y-4">
            <div>
                <h2 class="text-2xl font-semibold tracking-tight">Alert</h2>
                <p class="text-sm text-muted-foreground">Displays a callout for important information.</p>
            </div>
            <ComponentPreview Code="@_alertCode">
                <div class="w-full max-w-lg space-y-4">
                    <RnAlert>
                        <RnAlertTitle>Heads up!</RnAlertTitle>
                        <RnAlertDescription>You can add components to your app using the CLI.</RnAlertDescription>
                    </RnAlert>
                    <RnAlert Variant="AlertVariant.Destructive">
                        <RnAlertTitle>Error</RnAlertTitle>
                        <RnAlertDescription>Your session has expired. Please log in again.</RnAlertDescription>
                    </RnAlert>
                </div>
            </ComponentPreview>
        </section>

        <section class="space-y-4">
            <div>
                <h2 class="text-2xl font-semibold tracking-tight">Table</h2>
                <p class="text-sm text-muted-foreground">A responsive table component.</p>
            </div>
            <ComponentPreview Code="@_tableCode">
                <div class="w-full">
                    <RnTable>
                        <RnTableHeader>
                            <RnTableRow>
                                <RnTableHead>Invoice</RnTableHead>
                                <RnTableHead>Status</RnTableHead>
                                <RnTableHead>Method</RnTableHead>
                                <RnTableHead Class="text-right">Amount</RnTableHead>
                            </RnTableRow>
                        </RnTableHeader>
                        <RnTableBody>
                            <RnTableRow>
                                <RnTableCell>INV001</RnTableCell>
                                <RnTableCell><RnBadge>Paid</RnBadge></RnTableCell>
                                <RnTableCell>Credit Card</RnTableCell>
                                <RnTableCell Class="text-right">$250.00</RnTableCell>
                            </RnTableRow>
                            <RnTableRow>
                                <RnTableCell>INV002</RnTableCell>
                                <RnTableCell><RnBadge Variant="BadgeVariant.Outline">Pending</RnBadge></RnTableCell>
                                <RnTableCell>PayPal</RnTableCell>
                                <RnTableCell Class="text-right">$150.00</RnTableCell>
                            </RnTableRow>
                            <RnTableRow>
                                <RnTableCell>INV003</RnTableCell>
                                <RnTableCell><RnBadge Variant="BadgeVariant.Destructive">Overdue</RnBadge></RnTableCell>
                                <RnTableCell>Bank Transfer</RnTableCell>
                                <RnTableCell Class="text-right">$350.00</RnTableCell>
                            </RnTableRow>
                        </RnTableBody>
                    </RnTable>
                </div>
            </ComponentPreview>
        </section>

        <div class="flex justify-center py-8">
            <a href="/components" class="cn-button cn-button-variant-outline cn-button-size-lg">
                View all 50+ components
            </a>
        </div>
    </div>
</div>

@code {
    private string _activeTab = "account";

    private const string _buttonCode = @"<RnButton>Default</RnButton>
<RnButton Variant=""ButtonVariant.Secondary"">Secondary</RnButton>
<RnButton Variant=""ButtonVariant.Outline"">Outline</RnButton>
<RnButton Variant=""ButtonVariant.Ghost"">Ghost</RnButton>
<RnButton Variant=""ButtonVariant.Destructive"">Destructive</RnButton>
<RnButton Variant=""ButtonVariant.Link"">Link</RnButton>";

    private const string _cardCode = @"<RnCard>
    <RnCardHeader>
        <RnCardTitle>Card Title</RnCardTitle>
        <RnCardDescription>Card description.</RnCardDescription>
    </RnCardHeader>
    <RnCardContent>
        <RnLabel>Name</RnLabel>
        <RnInput Placeholder=""Your name"" />
    </RnCardContent>
    <RnCardFooter>
        <RnButton Variant=""ButtonVariant.Outline"">Cancel</RnButton>
        <RnButton>Deploy</RnButton>
