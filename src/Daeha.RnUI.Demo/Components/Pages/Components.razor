@page "/components"
@page "/components/{Slug}"
@layout DocsLayout

<PageTitle>@(_currentComponent?.Name ?? "Components") - RnUI</PageTitle>

@if (string.IsNullOrEmpty(Slug))
{
    <div class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Components</h1>
            <p class="text-lg text-muted-foreground">
                Beautifully designed components built with Tailwind CSS for Blazor.
            </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var component in _componentDemos)
            {
                <a href="/components/@component.Slug" class="group">
                    <RnCard Class="transition-colors hover:border-foreground/50">
                        <RnCardHeader>
                            <RnCardTitle>@component.Name</RnCardTitle>
                            <RnCardDescription>@component.Description</RnCardDescription>
                        </RnCardHeader>
                    </RnCard>
                </a>
            }
        </div>
    </div>
}
else if (_currentComponent is not null)
{
    <div class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">@_currentComponent.Name</h1>
            <p class="text-lg text-muted-foreground">@_currentComponent.Description</p>
        </div>
        <RnSeparator />
        @_currentComponent.Demo
    </div>
}
else
{
    <div class="space-y-4">
        <h1 class="text-3xl font-bold tracking-tight">Component not found</h1>
        <p class="text-muted-foreground">The component "@Slug" does not exist.</p>
        <RnButton OnClick="@(() => Navigation.NavigateTo("/components"))">Back to Components</RnButton>
    </div>
}

@inject ToastService ToastService

@code {
    [Parameter] public string? Slug { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private ComponentDemo? _currentComponent;

    // State for interactive demos
    private bool _checkboxValue;
    private bool _switchValue;
    private double _sliderValue = 50;
    private string _activeTab = "account";
    private bool _dialogOpen;
    private bool _sheetOpen;
    private bool _alertDialogOpen;
    private string? _expandedItem = "item-1";
    private bool _collapsibleOpen;
    private string? _selectValue;
    private string? _radioValue = "option-1";
    private bool _togglePressed;
    private int _currentPage = 1;

    // State for new component demos
    private DateTime? _calendarDate;
    private DateTime? _datePickerValue;
    private string? _comboboxValue;
    private bool _drawerOpen;
    private string? _toggleGroupValue = "center";
    private string _otpValue = "";

    protected override void OnParametersSet()
    {
        _currentComponent = string.IsNullOrEmpty(Slug)
            ? null
            : _componentDemos.FirstOrDefault(c => c.Slug == Slug);
    }

    private void ShowToast() => ToastService.Show("Event Created", "Your event has been created successfully.");
    private void ShowDestructiveToast() => ToastService.Show("Error", "Something went wrong.", ToastVariant.Destructive);

    private record ComponentDemo(string Name, string Slug, string Description, RenderFragment Demo);

    private ComponentDemo[] _componentDemos => [
        new("Accordion", "accordion", "A vertically stacked set of expandable items.",
            @<div class="space-y-4 max-w-md">
                <RnAccordion @bind-Value="_expandedItem">
                    <RnAccordionItem Value="item-1">
                        <RnAccordionTrigger>Is it accessible?</RnAccordionTrigger>
                        <RnAccordionContent>Yes. It adheres to the WAI-ARIA design pattern.</RnAccordionContent>
                    </RnAccordionItem>
                    <RnAccordionItem Value="item-2">
                        <RnAccordionTrigger>Is it styled?</RnAccordionTrigger>
                        <RnAccordionContent>Yes. It comes with default styles that match the other components' aesthetic.</RnAccordionContent>
                    </RnAccordionItem>
                    <RnAccordionItem Value="item-3">
                        <RnAccordionTrigger>Is it animated?</RnAccordionTrigger>
                        <RnAccordionContent>Yes. It's animated by default, but you can disable it if you prefer.</RnAccordionContent>
                    </RnAccordionItem>
                </RnAccordion>
            </div>
        ),

        new("Alert", "alert", "Displays a callout for important information.",
            @<div class="space-y-4 max-w-lg">
                <RnAlert>
                    <RnAlertTitle>Heads up!</RnAlertTitle>
                    <RnAlertDescription>You can add components to your app using the CLI.</RnAlertDescription>
                </RnAlert>
                <RnAlert Variant="AlertVariant.Destructive">
                    <RnAlertTitle>Error</RnAlertTitle>
                    <RnAlertDescription>Your session has expired. Please log in again.</RnAlertDescription>
                </RnAlert>
            </div>
        ),

        new("Alert Dialog", "alert-dialog", "A modal dialog that interrupts with important content.",
            @<div class="space-y-4">
                <RnButton Variant="ButtonVariant.Outline" OnClick="() => _alertDialogOpen = true">Show Alert Dialog</RnButton>
                <RnAlertDialog @bind-Open="_alertDialogOpen">
                    <RnAlertDialogHeader>
                        <RnAlertDialogTitle>Are you absolutely sure?</RnAlertDialogTitle>
                        <RnAlertDialogDescription>
                            This action cannot be undone. This will permanently delete your account
                            and remove your data from our servers.
                        </RnAlertDialogDescription>
                    </RnAlertDialogHeader>
                    <RnAlertDialogFooter>
                        <RnButton Variant="ButtonVariant.Outline" OnClick="() => _alertDialogOpen = false">Cancel</RnButton>
                        <RnButton OnClick="() => _alertDialogOpen = false">Continue</RnButton>
                    </RnAlertDialogFooter>
                </RnAlertDialog>
            </div>
        ),

        new("Aspect Ratio", "aspect-ratio", "Displays content within a desired ratio.",
            @<div class="space-y-4 max-w-md">
                <h3 class="text-sm font-medium">16:9 Ratio</h3>
                <RnAspectRatio Ratio="16.0 / 9.0" Class="bg-muted rounded-md overflow-hidden">
                    <div class="flex items-center justify-center h-full text-muted-foreground">
                        16:9 Content
                    </div>
                </RnAspectRatio>
                <h3 class="text-sm font-medium">4:3 Ratio</h3>
                <RnAspectRatio Ratio="4.0 / 3.0" Class="bg-muted rounded-md overflow-hidden">
                    <div class="flex items-center justify-center h-full text-muted-foreground">
                        4:3 Content
                    </div>
                </RnAspectRatio>
            </div>
        ),

        new("Avatar", "avatar", "An image element with a fallback for user profile images.",
            @<div class="space-y-4">
                <h3 class="text-sm font-medium">Sizes</h3>
                <div class="flex items-center gap-4">
                    <RnAvatar Size="ComponentSize.Sm"><span>SM</span></RnAvatar>
                    <RnAvatar Src="https://github.com/shadcn.png" Alt="shadcn" />
                    <RnAvatar Size="ComponentSize.Lg"><span>LG</span></RnAvatar>
                </div>
                <h3 class="text-sm font-medium">Avatar Group</h3>
                <RnAvatarGroup>
                    <RnAvatar><span>A</span></RnAvatar>
                    <RnAvatar><span>B</span></RnAvatar>
                    <RnAvatar><span>C</span></RnAvatar>
                    <RnAvatar><span>+2</span></RnAvatar>
                </RnAvatarGroup>
            </div>
        ),

        new("Badge", "badge", "Displays a badge or a component that looks like a badge.",
            @<div class="flex flex-col items-center gap-2">
                <div class="flex w-full flex-wrap gap-2">
                    <RnBadge>Badge</RnBadge>
                    <RnBadge Variant="BadgeVariant.Secondary">Secondary</RnBadge>
                    <RnBadge Variant="BadgeVariant.Destructive">Destructive</RnBadge>
                    <RnBadge Variant="BadgeVariant.Outline">Outline</RnBadge>
                </div>
                <div class="flex w-full flex-wrap gap-2">
                    <RnBadge Class="h-5 min-w-5 rounded-full px-1 font-mono tabular-nums">8</RnBadge>
                    <RnBadge Class="h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" Variant="BadgeVariant.Destructive">99</RnBadge>
                    <RnBadge Class="h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" Variant="BadgeVariant.Outline">20+</RnBadge>
                </div>
            </div>
        ),

        new("Breadcrumb", "breadcrumb", "Displays the path to the current resource.",
            @<div>
                <RnBreadcrumb>
                    <RnBreadcrumbItem>
                        <RnBreadcrumbLink Href="/">Home</RnBreadcrumbLink>
                    </RnBreadcrumbItem>
                    <RnBreadcrumbSeparator />
                    <RnBreadcrumbItem>
                        <RnBreadcrumbLink Href="/components">Components</RnBreadcrumbLink>
                    </RnBreadcrumbItem>
                    <RnBreadcrumbSeparator />
                    <RnBreadcrumbItem>
                        <RnBreadcrumbPage>Breadcrumb</RnBreadcrumbPage>
                    </RnBreadcrumbItem>
                </RnBreadcrumb>
            </div>
        ),

        new("Calendar", "calendar", "A date field component that allows users to enter and edit date.",
            @<div class="max-w-xs">
                <RnCalendar @bind-Selected="_calendarDate" />
                <p class="text-sm text-muted-foreground mt-2">Selected: @(_calendarDate?.ToString("MMM dd, yyyy") ?? "None")</p>
            </div>
        ),

        new("Carousel", "carousel", "A carousel with motion and swipe built on top of a slide container.",
            @<div class="max-w-xs mx-auto">
                <RnCarousel>
                    <RnCarouselContent>
                        @for (var i = 1; i <= 5; i++)
                        {
                            var index = i;
                            <RnCarouselItem>
                                <div class="p-1">
                                    <RnCard>
                                        <RnCardContent Class="flex aspect-square items-center justify-center p-6">
                                            <span class="text-4xl font-semibold">@index</span>
                                        </RnCardContent>
                                    </RnCard>
                                </div>
                            </RnCarouselItem>
                        }
                    </RnCarouselContent>
                    <RnCarouselPrevious />
                    <RnCarouselNext />
                </RnCarousel>
            </div>
        ),

        new("Button", "button", "Displays a button or a component that looks like a button.",
            @<div class="space-y-6">
                <div class="flex flex-wrap items-center gap-2">
                    <RnButton Variant="ButtonVariant.Outline">Button</RnButton>
                    <RnButton Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Submit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                    </RnButton>
                </div>
                <div class="flex flex-col items-start gap-8 sm:flex-row">
                    <div class="flex items-start gap-2">
                        <RnButton Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Small</RnButton>
                    </div>
                    <div class="flex items-start gap-2">
                        <RnButton Variant="ButtonVariant.Outline">Default</RnButton>
                    </div>
                    <div class="flex items-start gap-2">
                        <RnButton Variant="ButtonVariant.Outline" Size="ButtonSize.Lg">Large</RnButton>
                    </div>
                </div>
                <div class="flex flex-wrap gap-2">
                    <RnButton>Default</RnButton>
                    <RnButton Variant="ButtonVariant.Secondary">Secondary</RnButton>
                    <RnButton Variant="ButtonVariant.Destructive">Destructive</RnButton>
                    <RnButton Variant="ButtonVariant.Outline">Outline</RnButton>
                    <RnButton Variant="ButtonVariant.Ghost">Ghost</RnButton>
                    <RnButton Variant="ButtonVariant.Link">Link</RnButton>
                </div>
            </div>
        ),

        new("Button Group", "button-group", "A container that groups related buttons together with consistent styling.",
            @<div class="space-y-6">
                <div class="space-y-2">
                    <h3 class="text-sm font-medium">Horizontal (Default)</h3>
                    <RnButtonGroup>
                        <RnButton Variant="ButtonVariant.Outline">Button 1</RnButton>
                        <RnButton Variant="ButtonVariant.Outline">Button 2</RnButton>
                        <RnButton Variant="ButtonVariant.Outline">Button 3</RnButton>
                    </RnButtonGroup>
                </div>
                <div class="space-y-2">
                    <h3 class="text-sm font-medium">Vertical</h3>
                    <RnButtonGroup Orientation="ButtonGroupOrientation.Vertical">
                        <RnButton Variant="ButtonVariant.Outline">Button 1</RnButton>
                        <RnButton Variant="ButtonVariant.Outline">Button 2</RnButton>
                        <RnButton Variant="ButtonVariant.Outline">Button 3</RnButton>
                    </RnButtonGroup>
                </div>
                <div class="space-y-2">
                    <h3 class="text-sm font-medium">With Separator</h3>
                    <RnButtonGroup>
                        <RnButton Variant="ButtonVariant.Outline">Cut</RnButton>
                        <RnButtonGroupSeparator />
                        <RnButton Variant="ButtonVariant.Outline">Copy</RnButton>
                        <RnButtonGroupSeparator />
                        <RnButton Variant="ButtonVariant.Outline">Paste</RnButton>
                    </RnButtonGroup>
                </div>
                <div class="space-y-2">
                    <h3 class="text-sm font-medium">With Text</h3>
                    <RnButtonGroup>
                        <RnButtonGroupText>Prefix</RnButtonGroupText>
                        <RnButton Variant="ButtonVariant.Outline">Button</RnButton>
                    </RnButtonGroup>
                </div>
            </div>
        ),

        new("Card", "card", "Displays a card with header, content, and footer.",
            @<div class="grid gap-4 md:grid-cols-2">
                <RnCard>
                    <RnCardHeader>
                        <RnCardTitle>Card Title</RnCardTitle>
                        <RnCardDescription>Card description goes here.</RnCardDescription>
                    </RnCardHeader>
                    <RnCardContent>
                        <p>Card content with some example text.</p>
                    </RnCardContent>
                    <RnCardFooter>
                        <RnButton>Action</RnButton>
                    </RnCardFooter>
                </RnCard>
                <RnCard>
                    <RnCardHeader>
                        <RnCardTitle>Another Card</RnCardTitle>
                        <RnCardDescription>With different content.</RnCardDescription>
                    </RnCardHeader>
                    <RnCardContent>
                        <p>More example content here.</p>
                    </RnCardContent>
                </RnCard>
            </div>
        ),

        new("Checkbox", "checkbox", "A control that allows toggling between checked and unchecked.",
            @<div class="space-y-4">
                <div class="flex items-center space-x-2">
                    <RnCheckbox @bind-Checked="_checkboxValue" />
                    <RnLabel>Accept terms and conditions</RnLabel>
                </div>
                <p class="text-sm text-muted-foreground">Checked: @_checkboxValue</p>
            </div>
        ),

        new("Collapsible", "collapsible", "An interactive component that expands/collapses.",
            @<div class="max-w-md">
                <RnCollapsible @bind-Open="_collapsibleOpen">
                    <Trigger>
                        <div class="flex items-center justify-between space-x-4 px-4">
                            <h4 class="text-sm font-semibold">starred repositories</h4>
                            <RnButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm">
                                @(_collapsibleOpen ? "Hide" : "Show")
                            </RnButton>
                        </div>
                    </Trigger>
                    <ChildContent>
                        <div class="space-y-2 px-4 pt-2">
                            <div class="rounded-md border px-4 py-3 text-sm">shadcn/ui</div>
                            <div class="rounded-md border px-4 py-3 text-sm">tailwindcss/tailwindcss</div>
                            <div class="rounded-md border px-4 py-3 text-sm">dotnet/aspnetcore</div>
                        </div>
                    </ChildContent>
                </RnCollapsible>
            </div>
        ),

        new("Combobox", "combobox", "Autocomplete input and command palette with a list of suggestions.",
            @<div class="space-y-4">
                <RnCombobox @bind-Value="_comboboxValue" Placeholder="Select framework...">
                    <RnComboboxItem Value="next" Label="Next.js">Next.js</RnComboboxItem>
                    <RnComboboxItem Value="sveltekit" Label="SvelteKit">SvelteKit</RnComboboxItem>
                    <RnComboboxItem Value="nuxt" Label="Nuxt.js">Nuxt.js</RnComboboxItem>
                    <RnComboboxItem Value="remix" Label="Remix">Remix</RnComboboxItem>
                    <RnComboboxItem Value="astro" Label="Astro">Astro</RnComboboxItem>
                </RnCombobox>
                <p class="text-sm text-muted-foreground">Selected: @(_comboboxValue ?? "None")</p>
            </div>
        ),

        new("Command", "command", "Fast, composable, unstyled command menu.",
            @<div class="space-y-4 max-w-md">
                <RnCommand Class="rounded-lg border shadow-md">
                    <RnCommandInput Placeholder="Type a command or search..." />
                    <RnCommandList>
                        <RnCommandEmpty>No results found.</RnCommandEmpty>
                        <RnCommandGroup Heading="Suggestions">
                            <RnCommandItem>Calendar</RnCommandItem>
                            <RnCommandItem>Search Emoji</RnCommandItem>
                            <RnCommandItem>Calculator</RnCommandItem>
                        </RnCommandGroup>
                        <RnCommandSeparator />
                        <RnCommandGroup Heading="Settings">
                            <RnCommandItem>Profile</RnCommandItem>
                            <RnCommandItem>Billing</RnCommandItem>
                            <RnCommandItem>Settings</RnCommandItem>
                        </RnCommandGroup>
                    </RnCommandList>
                </RnCommand>
            </div>
        ),

        new("Context Menu", "context-menu", "A menu displayed on right-click.",
            @<div>
                <RnContextMenu>
                    <Trigger>
                        <div class="flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm">
                            Right click here
                        </div>
                    </Trigger>
                    <ChildContent>
                        <RnDropdownMenuLabel>Actions</RnDropdownMenuLabel>
                        <RnDropdownMenuSeparator />
                        <RnDropdownMenuItem>Back</RnDropdownMenuItem>
                        <RnDropdownMenuItem>Forward</RnDropdownMenuItem>
                        <RnDropdownMenuItem>Reload</RnDropdownMenuItem>
                    </ChildContent>
                </RnContextMenu>
            </div>
        ),

        new("Dialog", "dialog", "A window overlaid on the primary content.",
            @<div class="space-y-4">
                <RnButton OnClick="() => _dialogOpen = true">Open Dialog</RnButton>
                <RnDialog @bind-Open="_dialogOpen">
                    <RnDialogHeader>
                        <RnDialogTitle>Edit Profile</RnDialogTitle>
                        <RnDialogDescription>Make changes to your profile here. Click save when you're done.</RnDialogDescription>
                    </RnDialogHeader>
                    <div class="grid gap-4 py-4">
                        <div class="space-y-2">
                            <RnLabel>Name</RnLabel>
                            <RnInput Placeholder="Your name" />
                        </div>
                        <div class="space-y-2">
                            <RnLabel>Username</RnLabel>
                            <RnInput Placeholder="@("@username")" />
                        </div>
                    </div>
                    <RnDialogFooter>
                        <RnButton Variant="ButtonVariant.Outline" OnClick="() => _dialogOpen = false">Cancel</RnButton>
                        <RnButton OnClick="() => _dialogOpen = false">Save changes</RnButton>
                    </RnDialogFooter>
                </RnDialog>
            </div>
        ),

        new("Date Picker", "date-picker", "A date picker component with a calendar popup.",
            @<div class="space-y-4">
                <RnDatePicker @bind-Value="_datePickerValue" Placeholder="Pick a date" />
                <p class="text-sm text-muted-foreground">Selected: @(_datePickerValue?.ToString("MMM dd, yyyy") ?? "None")</p>
            </div>
        ),

        new("Drawer", "drawer", "A drawer component that slides from the bottom of the screen.",
            @<div class="space-y-4">
                <RnButton Variant="ButtonVariant.Outline" OnClick="() => _drawerOpen = true">Open Drawer</RnButton>
                <RnDrawer @bind-Open="_drawerOpen">
                    <RnDrawerContent>
                        <RnDrawerHeader>
                            <RnDrawerTitle>Move Goal</RnDrawerTitle>
                            <RnDrawerDescription>Set your daily activity goal.</RnDrawerDescription>
                        </RnDrawerHeader>
                        <div class="p-4">
                            <RnProgress Value="66" Class="w-full" />
                        </div>
                        <RnDrawerFooter>
                            <RnButton OnClick="() => _drawerOpen = false">Submit</RnButton>
                            <RnButton Variant="ButtonVariant.Outline" OnClick="() => _drawerOpen = false">Cancel</RnButton>
                        </RnDrawerFooter>
                    </RnDrawerContent>
                </RnDrawer>
            </div>
        ),

        new("Dropdown Menu", "dropdown-menu", "A menu displayed on trigger click.",
            @<div>
                <RnDropdownMenu>
                    <Trigger>
                        <RnButton Variant="ButtonVariant.Outline">Open Menu</RnButton>
                    </Trigger>
                    <ChildContent>
                        <RnDropdownMenuLabel>My Account</RnDropdownMenuLabel>
                        <RnDropdownMenuSeparator />
                        <RnDropdownMenuItem>Profile</RnDropdownMenuItem>
                        <RnDropdownMenuItem>Settings</RnDropdownMenuItem>
                        <RnDropdownMenuItem>Billing</RnDropdownMenuItem>
                        <RnDropdownMenuSeparator />
                        <RnDropdownMenuItem>Log out</RnDropdownMenuItem>
                    </ChildContent>
                </RnDropdownMenu>
            </div>
        ),

        new("Empty", "empty", "Empty state placeholder.",
            @<div class="max-w-md">
                <RnEmpty Class="border rounded-md py-12">
                    <p class="text-muted-foreground">No items to display.</p>
                </RnEmpty>
            </div>
        ),

        new("Form", "form", "Building forms with validation and accessible error messages.",
            @<div class="max-w-sm space-y-4">
                <RnFormItem>
                    <RnFormLabel For="username">Username</RnFormLabel>
                    <RnInput id="username" Placeholder="shadcn" />
                    <RnFormDescription>This is your public display name.</RnFormDescription>
                </RnFormItem>
                <RnFormItem>
                    <RnFormLabel For="email">Email</RnFormLabel>
                    <RnInput id="email" Type="email" Placeholder="m@example.com" />
                    <RnFormMessage Message="Please enter a valid email address." />
                </RnFormItem>
            </div>
        ),

        new("Hover Card", "hover-card", "Allows sighted users to preview content behind a link.",
            @<div>
                <RnHoverCard>
                    <Trigger>
                        <RnButton Variant="ButtonVariant.Link">Hover over me</RnButton>
                    </Trigger>
                    <ChildContent>
                        <div class="space-y-2">
                            <h4 class="text-sm font-semibold">RnUI</h4>
                            <p class="text-sm text-muted-foreground">A Blazor port of shadcn/ui components.</p>
                        </div>
                    </ChildContent>
                </RnHoverCard>
            </div>
        ),

        new("Input", "input", "Displays a form input field or a component that looks like an input field.",
            @<div class="space-y-6 max-w-sm">
                <RnInput Type="email" Placeholder="Email" />
                <div class="grid w-full items-center gap-3">
                    <RnLabel For="email-with-label">Email</RnLabel>
                    <RnInput Type="email" id="email-with-label" Placeholder="Email" />
                </div>
                <div class="grid w-full items-center gap-3">
                    <RnLabel For="picture">Picture</RnLabel>
                    <RnInput id="picture" Type="file" />
                </div>
                <RnInput Disabled="true" Type="email" Placeholder="Email" />
                <div class="flex w-full items-center gap-2">
                    <RnInput Type="email" Placeholder="Email" />
                    <RnButton Type="submit" Variant="ButtonVariant.Outline">Subscribe</RnButton>
                </div>
            </div>
        ),

        new("Input OTP", "input-otp", "Accessible one-time password component with copy paste functionality.",
            @<div class="space-y-4">
                <RnInputOTP @bind-Value="_otpValue" MaxLength="6">
                    <RnInputOTPGroup>
                        <RnInputOTPSlot Index="0" />
                        <RnInputOTPSlot Index="1" />
                        <RnInputOTPSlot Index="2" />
                    </RnInputOTPGroup>
                    <RnInputOTPSeparator />
                    <RnInputOTPGroup>
                        <RnInputOTPSlot Index="3" />
                        <RnInputOTPSlot Index="4" />
                        <RnInputOTPSlot Index="5" />
                    </RnInputOTPGroup>
                </RnInputOTP>
                <p class="text-sm text-muted-foreground">Value: @(_otpValue)</p>
            </div>
        ),

        new("Kbd", "kbd", "Displays a keyboard key or shortcut.",
            @<div class="flex flex-col items-center gap-4">
                <RnKbdGroup>
                    <RnKbd>⌘</RnKbd>
                    <RnKbd>⇧</RnKbd>
                    <RnKbd>⌥</RnKbd>
                    <RnKbd>⌃</RnKbd>
                </RnKbdGroup>
                <RnKbdGroup>
                    <RnKbd>Ctrl</RnKbd>
                    <span>+</span>
                    <RnKbd>B</RnKbd>
                </RnKbdGroup>
            </div>
