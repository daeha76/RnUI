                        </RnNavigationMenuItem>
                        <RnNavigationMenuItem>
                            <RnNavigationMenuTrigger>Components</RnNavigationMenuTrigger>
                            <RnNavigationMenuContent>
                                <div class="grid gap-3 p-4 w-[400px]">
                                    <RnNavigationMenuLink Href="#">Alert Dialog</RnNavigationMenuLink>
                                    <RnNavigationMenuLink Href="#">Hover Card</RnNavigationMenuLink>
