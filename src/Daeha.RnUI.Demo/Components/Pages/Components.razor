                <RnButton Variant="ButtonVariant.Outline" OnClick="() => _alertDialogOpen = true">Show Alert Dialog</RnButton>
                <RnAlertDialog @bind-Open="_alertDialogOpen">
                    <RnAlertDialogHeader>
                        <RnAlertDialogTitle>Are you absolutely sure?</RnAlertDialogTitle>
                        <RnAlertDialogDescription>
                            This action cannot be undone. This will permanently delete your account
                            and remove your data from our servers.
                        </RnAlertDialogDescription>
                    </RnAlertDialogHeader>
                    <RnAlertDialogFooter>
                        <RnButton Variant="ButtonVariant.Outline" OnClick="() => _alertDialogOpen = false">Cancel</RnButton>
                        <RnButton OnClick="() => _alertDialogOpen = false">Continue</RnButton>
                    </RnAlertDialogFooter>
                </RnAlertDialog>
            </div>
        ),

