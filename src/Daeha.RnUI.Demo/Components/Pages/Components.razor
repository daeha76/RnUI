            </div>
        ),

        new("Tabs", "tabs", "A set of layered sections of content, shown one at a time.",
            @<div class="flex w-full max-w-sm flex-col gap-6">
                <RnTabs @bind-ActiveTab="_activeTab">
                    <RnTabsList>
                        <RnTabsTrigger Value="account">Account</RnTabsTrigger>
                        <RnTabsTrigger Value="password">Password</RnTabsTrigger>
                    </RnTabsList>
                    <RnTabsContent Value="account">
                        <RnCard>
                            <RnCardHeader>
                                <RnCardTitle>Account</RnCardTitle>
                                <RnCardDescription>Make changes to your account here. Click save when you're done.</RnCardDescription>
                            </RnCardHeader>
                            <RnCardContent>
                                <div class="grid gap-6">
                                    <div class="grid gap-3">
                                        <RnLabel For="tabs-demo-name">Name</RnLabel>
                                        <RnInput id="tabs-demo-name" Placeholder="Pedro Duarte" />
                                    </div>
                                    <div class="grid gap-3">
                                        <RnLabel For="tabs-demo-username">Username</RnLabel>
                                        <RnInput id="tabs-demo-username" Placeholder="@@peduarte" />
                                    </div>
                                </div>
                            </RnCardContent>
                            <RnCardFooter>
                                <RnButton>Save changes</RnButton>
                            </RnCardFooter>
                        </RnCard>
                    </RnTabsContent>
                    <RnTabsContent Value="password">
                        <RnCard>
                            <RnCardHeader>
                                <RnCardTitle>Password</RnCardTitle>
                                <RnCardDescription>Change your password here. After saving, you'll be logged out.</RnCardDescription>
                            </RnCardHeader>
                            <RnCardContent>
                                <div class="grid gap-6">
                                    <div class="grid gap-3">
                                        <RnLabel For="tabs-demo-current">Current password</RnLabel>
                                        <RnInput id="tabs-demo-current" Type="password" />
                                    </div>
                                    <div class="grid gap-3">
                                        <RnLabel For="tabs-demo-new">New password</RnLabel>
                                        <RnInput id="tabs-demo-new" Type="password" />
                                    </div>
                                </div>
                            </RnCardContent>
                            <RnCardFooter>
                                <RnButton>Save password</RnButton>
                            </RnCardFooter>
                        </RnCard>
                    </RnTabsContent>
                </RnTabs>
            </div>
        ),

        new("Textarea", "textarea", "Displays a form textarea or a component that looks like a textarea.",
            @<RnTextarea Placeholder="Type your message here." Class="max-w-sm" />
        ),

        new("Toast", "toast", "A succinct message that is displayed temporarily.",
            @<div class="space-y-4">
                <RnButton OnClick="ShowToast">Show Toast</RnButton>
                <RnButton Variant="ButtonVariant.Destructive" OnClick="ShowDestructiveToast">Destructive Toast</RnButton>
            </div>
        ),

        new("Toggle", "toggle", "A two-state button that can be on or off.",
            @<div class="flex gap-4">
                <RnToggle aria-label="Toggle bold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/>
                    </svg>
                </RnToggle>
                <RnToggle Variant="ToggleVariant.Outline" aria-label="Toggle italic">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" x2="10" y1="4" y2="4"/><line x1="14" x2="5" y1="20" y2="20"/><line x1="15" x2="9" y1="4" y2="20"/>
                    </svg>
                </RnToggle>
                <RnToggle aria-label="Toggle underline" Disabled="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" x2="20" y1="20" y2="20"/>
                    </svg>
                </RnToggle>
            </div>
        ),

        new("Toggle Group", "toggle-group", "A set of two-state buttons that can be toggled on or off.",
            @<RnToggleGroup @bind-Value="_toggleGroupValue">
                <RnToggleGroupItem Value="bold" aria-label="Toggle bold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
                </RnToggleGroupItem>
                <RnToggleGroupItem Value="italic" aria-label="Toggle italic">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" x2="10" y1="4" y2="4"/><line x1="14" x2="5" y1="20" y2="20"/><line x1="15" x2="9" y1="4" y2="20"/></svg>
                </RnToggleGroupItem>
                <RnToggleGroupItem Value="underline" aria-label="Toggle underline">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" x2="20" y1="20" y2="20"/></svg>
                </RnToggleGroupItem>
            </RnToggleGroup>
        ),

        new("Tooltip", "tooltip", "A popup that displays information on hover.",
            @<div>
                <RnTooltip>
                    <Trigger>
                        <RnButton Variant="ButtonVariant.Outline">Hover me</RnButton>
                    </Trigger>
                    <ChildContent>
                        <p>Add to library</p>
                    </ChildContent>
                </RnTooltip>
            </div>
        ),
    ];
}
