@page "/components"
@page "/components/{Slug}"
@layout DocsLayout

<PageTitle>@(_currentComponent?.Name ?? "Components") - RnUI</PageTitle>

@if (string.IsNullOrEmpty(Slug))
{
    <div class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Components</h1>
            <p class="text-lg text-muted-foreground">
                Beautifully designed components built with Tailwind CSS for Blazor.
            </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            @foreach (var component in _componentDemos)
            {
                <a href="/components/@component.Slug" class="group">
                    <RnCard Class="transition-colors hover:border-foreground/50">
                        <RnCardHeader>
                            <RnCardTitle>@component.Name</RnCardTitle>
                            <RnCardDescription>@component.Description</RnCardDescription>
                        </RnCardHeader>
                    </RnCard>
                </a>
            }
        </div>
    </div>
}
else if (_currentComponent is not null)
{
    <div class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">@_currentComponent.Name</h1>
            <p class="text-lg text-muted-foreground">@_currentComponent.Description</p>
        </div>
        <RnSeparator />
        @_currentComponent.Demo
    </div>
}
else
{
    <div class="space-y-4">
        <h1 class="text-3xl font-bold tracking-tight">Component not found</h1>
        <p class="text-muted-foreground">The component "@Slug" does not exist.</p>
        <RnButton OnClick="@(() => Navigation.NavigateTo("/components"))">Back to Components</RnButton>
    </div>
}

@inject ToastService ToastService

@code {
    [Parameter] public string? Slug { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private ComponentDemo? _currentComponent;

    // State for interactive demos
    private bool _checkboxValue;
    private bool _switchValue;
    private double _sliderValue = 50;
    private string _activeTab = "account";
    private bool _dialogOpen;
    private bool _sheetOpen;
    private bool _alertDialogOpen;
    private string? _expandedItem = "item-1";
    private bool _collapsibleOpen;
    private string? _selectValue;
    private string? _radioValue = "comfortable";
    private int _currentPage = 1;

    // State for new component demos
    private DateTime? _calendarDate;
    private DateTime? _datePickerValue;
    private string? _comboboxValue;
    private bool _drawerOpen;
    private int _drawerGoal = 350;
    private string? _toggleGroupValue = "center";
    private string _otpValue = "";

    protected override void OnParametersSet()
    {
        _currentComponent = string.IsNullOrEmpty(Slug)
            ? null
            : _componentDemos.FirstOrDefault(c => c.Slug == Slug);
    }

    private void ShowToast() => ToastService.Show("Event Created", "Your event has been created successfully.");
    private void ShowDestructiveToast() => ToastService.Show("Error", "Something went wrong.", ToastVariant.Destructive);

    private record ComponentDemo(string Name, string Slug, string Description, RenderFragment Demo);

    private ComponentDemo[] _componentDemos => [
        new("Accordion", "accordion", "A vertically stacked set of expandable items.",
