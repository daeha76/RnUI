@page "/docs/theming"
@layout DocsLayout

<PageTitle>Theming - RnUI</PageTitle>

<div class="space-y-8 max-w-3xl">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Theming</h1>
        <p class="text-lg text-muted-foreground mt-2">
            Customize colors, fonts, and spacing using CSS variables.
        </p>
    </div>

    <RnSeparator />

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight">CSS Variables</h2>
        <p class="text-sm text-muted-foreground">
            RnUI uses OKLCH color system via Tailwind CSS v4 theme variables.
            Override these in your own CSS to customize the look:
        </p>
        <div class="rounded-md bg-muted p-4 overflow-x-auto">
            <pre class="text-sm"><code>@@theme {
  --color-background: oklch(1 0 0);
  --color-foreground: oklch(0.145 0 0);
  --color-primary: oklch(0.205 0 0);
  --color-primary-foreground: oklch(0.985 0 0);
  --color-secondary: oklch(0.965 0 0);
  --color-muted: oklch(0.965 0 0);
  --color-accent: oklch(0.965 0 0);
  --color-destructive: oklch(0.577 0.245 27.325);
  --color-border: oklch(0.922 0 0);
  --color-ring: oklch(0.708 0 0);
  --radius-lg: 0.5rem;
}</code></pre>
        </div>
    </section>

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight">Dark Mode</h2>
        <p class="text-sm text-muted-foreground">
            Add the <code class="text-sm bg-muted px-1 py-0.5 rounded">dark</code> class to your HTML element:
        </p>
        <div class="rounded-md bg-muted p-4 overflow-x-auto">
            <pre class="text-sm"><code>&lt;html class="dark"&gt;</code></pre>
        </div>
        <p class="text-sm text-muted-foreground">
            All components automatically adjust their colors based on the dark mode class.
        </p>
    </section>

    <section class="space-y-4">
        <h2 class="text-2xl font-semibold tracking-tight">Color Palette Preview</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-background border"></div>
                <p class="text-xs text-muted-foreground">background</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-foreground"></div>
                <p class="text-xs text-muted-foreground">foreground</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-primary"></div>
                <p class="text-xs text-muted-foreground">primary</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-secondary"></div>
                <p class="text-xs text-muted-foreground">secondary</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-muted"></div>
                <p class="text-xs text-muted-foreground">muted</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-accent"></div>
                <p class="text-xs text-muted-foreground">accent</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-destructive"></div>
                <p class="text-xs text-muted-foreground">destructive</p>
            </div>
            <div class="space-y-1.5">
                <div class="h-12 rounded-md bg-card border"></div>
                <p class="text-xs text-muted-foreground">card</p>
            </div>
        </div>
    </section>
</div>
