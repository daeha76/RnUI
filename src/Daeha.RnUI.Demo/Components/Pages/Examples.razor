@page "/examples"

<PageTitle>Examples - RnUI</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Examples</h1>
        <p class="text-muted-foreground">Example layouts and compositions using RnUI components.</p>
    </div>

    @* Dialog Example *@
    <section class="space-y-4">
        <h2 class="text-2xl font-semibold">Dialog</h2>
        <RnButton OnClick="() => _dialogOpen = true">Open Dialog</RnButton>
        <RnDialog @bind-Open="_dialogOpen">
            <RnDialogHeader>
                <RnDialogTitle>Edit Profile</RnDialogTitle>
                <RnDialogDescription>Make changes to your profile here. Click save when you're done.</RnDialogDescription>
            </RnDialogHeader>
            <div class="grid gap-4 py-4">
                <div class="space-y-2">
                    <RnLabel>Name</RnLabel>
                    <RnInput Placeholder="Your name" />
                </div>
                <div class="space-y-2">
                    <RnLabel>Username</RnLabel>
                    <RnInput Placeholder="@("@username")" />
                </div>
            </div>
            <RnDialogFooter>
                <RnButton Variant="ButtonVariant.Outline" OnClick="() => _dialogOpen = false">Cancel</RnButton>
                <RnButton OnClick="() => _dialogOpen = false">Save changes</RnButton>
            </RnDialogFooter>
        </RnDialog>
    </section>

    <RnSeparator />

    @* Sheet Example *@
    <section class="space-y-4">
        <h2 class="text-2xl font-semibold">Sheet</h2>
        <div class="flex gap-4">
            <RnButton Variant="ButtonVariant.Outline" OnClick="() => _sheetOpen = true">Open Sheet (Right)</RnButton>
        </div>
        <RnSheet @bind-Open="_sheetOpen" Side="Side.Right">
            <RnSheetHeader>
                <RnSheetTitle>Edit Profile</RnSheetTitle>
                <RnSheetDescription>Make changes to your profile.</RnSheetDescription>
            </RnSheetHeader>
            <div class="grid gap-4 py-4">
                <div class="space-y-2">
                    <RnLabel>Name</RnLabel>
                    <RnInput Placeholder="Your name" />
                </div>
            </div>
            <RnSheetFooter>
                <RnButton OnClick="() => _sheetOpen = false">Save changes</RnButton>
            </RnSheetFooter>
        </RnSheet>
    </section>

    <RnSeparator />

    @* Accordion Example *@
    <section class="space-y-4">
        <h2 class="text-2xl font-semibold">Accordion</h2>
        <RnAccordion @bind-ExpandedItem="_expandedItem" Class="max-w-md">
            <RnAccordionItem Value="item-1">
                <RnAccordionTrigger>Is it accessible?</RnAccordionTrigger>
                <RnAccordionContent>Yes. It adheres to the WAI-ARIA design pattern.</RnAccordionContent>
            </RnAccordionItem>
            <RnAccordionItem Value="item-2">
                <RnAccordionTrigger>Is it styled?</RnAccordionTrigger>
                <RnAccordionContent>
                    Yes. It comes with default styles that match the other components' aesthetic.
                </RnAccordionContent>
            </RnAccordionItem>
            <RnAccordionItem Value="item-3">
                <RnAccordionTrigger>Is it animated?</RnAccordionTrigger>
                <RnAccordionContent>
                    Yes. It's animated by default, but you can disable it if you prefer.
                </RnAccordionContent>
            </RnAccordionItem>
        </RnAccordion>
    </section>
</div>

@code {
    private bool _dialogOpen;
    private bool _sheetOpen;
    private string? _expandedItem = "item-1";
}
