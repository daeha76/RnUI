@inject NavigationManager Navigation
@implements IDisposable

<RnSidebar Open="true" Width="100%">
    <RnSidebarContent>
        <RnSidebarGroup>
            <RnSidebarGroupLabel>Getting Started</RnSidebarGroupLabel>
            <RnSidebarMenu>
                <RnSidebarMenuItem>
                    <RnSidebarMenuButton Href="/docs/getting-started" IsActive="@IsCurrentPage("/docs/getting-started")">
                        Getting Started
                    </RnSidebarMenuButton>
                </RnSidebarMenuItem>
                <RnSidebarMenuItem>
                    <RnSidebarMenuButton Href="/docs/theming" IsActive="@IsCurrentPage("/docs/theming")">
                        Theming
                    </RnSidebarMenuButton>
                </RnSidebarMenuItem>
                <RnSidebarMenuItem>
                    <RnSidebarMenuButton Href="/components" IsActive="@IsCurrentPage("/components")">
                        Components
                    </RnSidebarMenuButton>
                </RnSidebarMenuItem>
            </RnSidebarMenu>
        </RnSidebarGroup>

        <RnSidebarGroup>
            <RnSidebarGroupLabel>Components</RnSidebarGroupLabel>
            <RnSidebarMenu>
                @foreach (var component in _components)
                {
                    var href = $"/components/{component.Slug}";
                    <RnSidebarMenuItem>
                        <RnSidebarMenuButton Href="@href" IsActive="@IsCurrentPage(href)">
                            @component.Name
                        </RnSidebarMenuButton>
                    </RnSidebarMenuItem>
                }
            </RnSidebarMenu>
        </RnSidebarGroup>
    </RnSidebarContent>
</RnSidebar>

@code {
    private record ComponentItem(string Name, string Slug);

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool IsCurrentPage(string href) =>
        Navigation.Uri.TrimEnd('/').EndsWith(href, StringComparison.OrdinalIgnoreCase);

    private readonly ComponentItem[] _components =
    [
        new("Accordion", "accordion"),
        new("Alert", "alert"),
        new("Alert Dialog", "alert-dialog"),
        new("Aspect Ratio", "aspect-ratio"),
        new("Avatar", "avatar"),
        new("Badge", "badge"),
        new("Breadcrumb", "breadcrumb"),
        new("Button", "button"),
        new("Calendar", "calendar"),
        new("Card", "card"),
        new("Carousel", "carousel"),
        new("Checkbox", "checkbox"),
        new("Collapsible", "collapsible"),
        new("Combobox", "combobox"),
        new("Command", "command"),
        new("Context Menu", "context-menu"),
        new("Date Picker", "date-picker"),
        new("Dialog", "dialog"),
        new("Drawer", "drawer"),
        new("Dropdown Menu", "dropdown-menu"),
        new("Empty", "empty"),
        new("Form", "form"),
        new("Hover Card", "hover-card"),
        new("Input", "input"),
        new("Input OTP", "input-otp"),
        new("Kbd", "kbd"),
        new("Label", "label"),
        new("Menubar", "menubar"),
        new("Navigation Menu", "navigation-menu"),
        new("Pagination", "pagination"),
        new("Popover", "popover"),
        new("Progress", "progress"),
        new("Radio Group", "radio-group"),
        new("Resizable", "resizable"),
        new("Scroll Area", "scroll-area"),
        new("Select", "select"),
        new("Separator", "separator"),
        new("Sheet", "sheet"),
        new("Sidebar", "sidebar"),
        new("Skeleton", "skeleton"),
        new("Slider", "slider"),
        new("Spinner", "spinner"),
        new("Switch", "switch"),
        new("Table", "table"),
        new("Tabs", "tabs"),
        new("Textarea", "textarea"),
        new("Toast", "toast"),
        new("Toggle", "toggle"),
        new("Toggle Group", "toggle-group"),
        new("Tooltip", "tooltip"),
    ];
}
