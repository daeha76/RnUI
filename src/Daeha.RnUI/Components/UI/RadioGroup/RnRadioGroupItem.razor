@* RnRadioGroupItem component *@

<button type="button" role="radio"
        data-slot="radio-group-item"
        data-state="@(IsSelected ? "checked" : "unchecked")"
        aria-checked="@IsSelected.ToString().ToLower()"
        class="@CssUtils.Cn("cn-radio-group-item", Class)"
        disabled="@(Disabled ? true : (object?)null)"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @if (IsSelected)
    {
        <span data-slot="radio-group-indicator" class="cn-radio-group-indicator">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="12" cy="12" r="12" />
            </svg>
        </span>
    }
</button>

@code {
    [CascadingParameter] public RnRadioGroup? Parent { get; set; }
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsSelected => Parent?.Value == Value;

    private async Task HandleClick()
    {
        if (Parent is not null)
            await Parent.SelectValue(Value);
    }
}
