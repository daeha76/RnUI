@* RnTextField component - Convenience wrapper for RnField + RnFieldLabel + RnInput *@

<RnField Orientation="@Orientation" Class="@Class">
    @if (Label is not null)
    {
        <RnFieldLabel For="@Id" Class="@LabelClass">@Label</RnFieldLabel>
    }
    <RnInput Type="@Type"
             Value="@Value"
             ValueChanged="@ValueChanged"
             Placeholder="@Placeholder"
             Disabled="@Disabled"
             Class="@InputClass"
             @attributes="AdditionalAttributes" />
    @if (Description is not null)
    {
        <RnFieldDescription>@Description</RnFieldDescription>
    }
</RnField>

@code {
    /// <summary>Label text. When null, no label is rendered.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Optional description text below the input.</summary>
    [Parameter] public string? Description { get; set; }

    /// <summary>Input value (string).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Input placeholder text.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Input type (text, password, email, etc.).</summary>
    [Parameter] public string Type { get; set; } = "text";

    /// <summary>Whether the input is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Id for the input element. Also used for label's "for" attribute.</summary>
    [Parameter] public string? Id { get; set; }

    /// <summary>Layout orientation of the field.</summary>
    [Parameter] public FieldOrientation Orientation { get; set; } = FieldOrientation.Vertical;

    /// <summary>Additional CSS classes for the outer RnField wrapper.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Additional CSS classes for the inner RnInput.</summary>
    [Parameter] public string? InputClass { get; set; }

    /// <summary>Additional CSS classes for the RnFieldLabel.</summary>
    [Parameter] public string? LabelClass { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
