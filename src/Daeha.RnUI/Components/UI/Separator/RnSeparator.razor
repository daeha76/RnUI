@* RnSeparator component - Blazor port of shadcn/ui Separator *@

<div data-slot="separator"
     role="separator"
     data-orientation="@Orientation.ToString().ToLowerInvariant()"
     class="@ComputedClass"
     @attributes="AdditionalAttributes"></div>

@code {
    /// <summary>Orientation of the separator.</summary>
    [Parameter] public Orientation Orientation { get; set; } = Orientation.Horizontal;

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => CssUtils.Cn(
        "cn-separator",
        Class
    );
}
