@* RnAlertDialog component - Blazor port of shadcn/ui RnAlertDialog *@

@if (Open)
{
    <div data-slot="alert-dialog">
        @* Overlay - fixed backdrop *@
        <div data-slot="alert-dialog-overlay"
             class="fixed inset-0 z-50 bg-black/80" style="backdrop-filter: blur(4px);"></div>

        @* Content - centered dialog panel *@
        <div data-slot="alert-dialog-content"
             class="@CssUtils.Cn("fixed left-1/2 top-1/2 z-50 grid w-full max-w-lg -translate-x-1/2 -translate-y-1/2 gap-4 border border-border bg-background p-6 shadow-lg sm:rounded-lg duration-200", Class)"
             @attributes="AdditionalAttributes">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
