@* RnCalendar component - Blazor port of shadcn/ui Calendar *@

<div data-slot="calendar" data-size="@SizeValue" class="@ComputedClass" @attributes="AdditionalAttributes">
    @* Header: month navigation *@
    <div class="cn-calendar-nav">
        <button type="button" class="cn-calendar-nav-button" @onclick="PreviousMonth">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="cn-calendar-caption">
            @_displayMonth.ToString("MMMM yyyy")
        </div>
        <button type="button" class="cn-calendar-nav-button" @onclick="NextMonth">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m9 18 6-6-6-6"/></svg>
        </button>
    </div>

    @* Day headers *@
    <div class="cn-calendar-weekdays">
        @foreach (var day in new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" })
        {
            <div class="cn-calendar-weekday">@day</div>
        }
    </div>

    @* Day grid *@
    <div class="cn-calendar-grid">
        @foreach (var date in GetCalendarDays())
        {
            var isCurrentMonth = date.Month == _displayMonth.Month;
            var isSelected = Selected.HasValue && date.Date == Selected.Value.Date;
            var isToday = date.Date == DateTime.Today;
            var isDisabled = (MinDate.HasValue && date.Date < MinDate.Value.Date) ||
                             (MaxDate.HasValue && date.Date > MaxDate.Value.Date);
            var capturedDate = date;

            <button type="button"
                    disabled="@(isDisabled ? true : (object?)null)"
                    class="@GetDayClass(isCurrentMonth, isSelected, isToday, isDisabled)"
                    @onclick="() => SelectDate(capturedDate)">
                @date.Day
            </button>
        }
    </div>
</div>

@code {
    /// <summary>Currently selected date.</summary>
    [Parameter] public DateTime? Selected { get; set; }

    /// <summary>Callback when selected date changes.</summary>
    [Parameter] public EventCallback<DateTime?> SelectedChanged { get; set; }

    /// <summary>Currently displayed month.</summary>
    [Parameter] public DateTime DisplayMonth { get; set; } = DateTime.Today;

    /// <summary>Minimum selectable date (inclusive).</summary>
    [Parameter] public DateTime? MinDate { get; set; }

    /// <summary>Maximum selectable date (inclusive).</summary>
    [Parameter] public DateTime? MaxDate { get; set; }

    /// <summary>Size of the calendar.</summary>
    [Parameter] public ComponentSize Size { get; set; } = ComponentSize.Default;

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string SizeValue => Size == ComponentSize.Sm ? "sm" : "default";

    private string ComputedClass => CssUtils.Cn("cn-calendar", Class);

    private DateTime _displayMonth;

    protected override void OnParametersSet()
    {
        // Sync internal display month from parameter when it changes
        // but only if _displayMonth hasn't been set yet (first render)
        if (_displayMonth == default)
        {
            _displayMonth = new DateTime(DisplayMonth.Year, DisplayMonth.Month, 1);
        }
    }

    private IEnumerable<DateTime> GetCalendarDays()
    {
        var firstOfMonth = new DateTime(_displayMonth.Year, _displayMonth.Month, 1);
        // Start from Sunday before (or on) the first of the month
        var startDate = firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);

        // Return exactly 42 days (6 weeks)
        for (var i = 0; i < 42; i++)
        {
            yield return startDate.AddDays(i);
        }
    }

    private string GetDayClass(bool isCurrentMonth, bool isSelected, bool isToday, bool isDisabled)
    {
        var classes = "cn-calendar-day";

        if (isDisabled)
            classes += " cn-calendar-day-disabled";
        else if (isSelected)
            classes += " cn-calendar-day-selected";
        else if (isToday)
            classes += " cn-calendar-day-today";

        if (!isCurrentMonth && !isDisabled)
            classes += " cn-calendar-day-outside";

        return classes;
    }

    private void PreviousMonth()
    {
        _displayMonth = _displayMonth.AddMonths(-1);
    }

    private void NextMonth()
    {
        _displayMonth = _displayMonth.AddMonths(1);
    }

    private async Task SelectDate(DateTime date)
    {
        Selected = date;
        await SelectedChanged.InvokeAsync(date);
    }
}
