@* RnSlider component - Blazor port of shadcn/ui RnSlider *@

<div data-slot="slider"
     role="slider"
     aria-valuemin="@Min"
     aria-valuemax="@Max"
     aria-valuenow="@Value"
     data-disabled="@(Disabled ? "" : null)"
     class="@CssUtils.Cn("cn-slider", Class)"
     @attributes="AdditionalAttributes">
    <div data-slot="slider-track" data-orientation="horizontal" class="cn-slider-track">
        <div data-slot="slider-range" data-orientation="horizontal" class="cn-slider-range" style="width: @(Percentage)%"></div>
    </div>
    <input type="range" min="@Min" max="@Max" step="@Step" value="@Value"
           class="absolute inset-0 cursor-pointer opacity-0"
           disabled="@(Disabled ? true : (object?)null)"
           @oninput="HandleInput" />
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private double Percentage => Max > Min ? ((Value - Min) / (Max - Min)) * 100 : 0;

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            Value = val;
            await ValueChanged.InvokeAsync(val);
        }
    }
}
