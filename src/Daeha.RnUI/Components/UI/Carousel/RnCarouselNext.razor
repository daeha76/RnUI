@* RnCarouselNext - Next slide button for carousel *@

<RnButton type="button"
          data-slot="carousel-next"
          Variant="ButtonVariant.Outline"
          Size="ButtonSize.Icon"
          aria-label="Next slide"
          disabled="@(!(Carousel?.CanGoNext ?? false))"
          class="@CssUtils.Cn("cn-carousel-next absolute h-8 w-8 rounded-full -right-12 top-1/2 -translate-y-1/2", Class)"
          @onclick="HandleClick"
          @attributes="AdditionalAttributes">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
         aria-hidden="true">
        <path d="m9 18 6-6-6-6" />
    </svg>
    <span class="sr-only">Next slide</span>
</RnButton>

@code {
    [CascadingParameter] public RnCarousel? Carousel { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private void HandleClick() => Carousel?.Next();
}
