@* RnAccordion component - Blazor port of shadcn/ui Accordion *@

<CascadingValue Value="this" IsFixed="false">
    <div data-slot="accordion"
         class="@CssUtils.Cn(Class)"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    /// <summary>Child content containing RnAccordionItem components.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>The currently expanded item value (single mode).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when the expanded item changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>When Multiple, allows multiple items to be expanded simultaneously. Default is Single.</summary>
    [Parameter] public AccordionType Type { get; set; } = AccordionType.Single;

    /// <summary>When true and type is Single, allows the expanded item to be collapsed.</summary>
    [Parameter] public bool Collapsible { get; set; } = true;

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly HashSet<string> _expandedItems = new();

    internal bool IsItemExpanded(string value)
        => Type == AccordionType.Multiple ? _expandedItems.Contains(value) : Value == value;

    internal async Task Toggle(string value)
    {
        if (Type == AccordionType.Multiple)
        {
            if (!_expandedItems.Remove(value))
                _expandedItems.Add(value);
            StateHasChanged();
        }
        else
        {
            if (Value == value && Collapsible)
                Value = null;
            else
                Value = value;

            await ValueChanged.InvokeAsync(Value);
            StateHasChanged();
        }
    }
}
