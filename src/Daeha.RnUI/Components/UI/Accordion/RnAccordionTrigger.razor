<h3 data-slot="accordion-header" class="flex">
    <button type="button"
            data-slot="accordion-trigger"
            disabled="@Item?.Disabled"
            aria-expanded="@(IsExpanded ? "true" : "false")"
            aria-disabled="@(Item?.Disabled == true ? "true" : null)"
            class="@CssUtils.Cn(
                "cursor-pointer focus-visible:border-ring focus-visible:ring-ring/50 flex flex-1 items-start justify-between gap-4 rounded-md py-4 text-left text-sm font-medium leading-6 transition-all outline-none hover:underline focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50",
                Class)"
            @onclick="HandleClick"
            @attributes="AdditionalAttributes">
        @ChildContent
        <svg xmlns="http://www.w3.org/2000/svg"
             width="16" height="16"
             viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round"
             style="transform: rotate(@(IsExpanded ? "180deg" : "0deg")); transition: transform 200ms ease;"
             class="text-muted-foreground pointer-events-none size-4 shrink-0 translate-y-0.5"
             data-slot="accordion-trigger-icon">
            <path d="m6 9 6 6 6-6" />
        </svg>
    </button>
</h3>

@code {
    [CascadingParameter] public RnAccordionItem? Item { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsExpanded => Item?.IsExpanded ?? false;

    private async Task HandleClick()
    {
        if (Item is not null)
            await Item.Toggle();
    }
}
