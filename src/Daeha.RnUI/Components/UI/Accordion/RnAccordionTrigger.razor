<h3 data-slot="accordion-header" class="flex">
    <button type="button"
            data-slot="accordion-trigger"
            data-state="@(IsExpanded ? "open" : "closed")"
            disabled="@Item?.Disabled"
            aria-expanded="@(IsExpanded ? "true" : "false")"
            aria-disabled="@(Item?.Disabled == true ? "true" : null)"
            class="@CssUtils.Cn("cn-accordion-trigger cursor-pointer", Class)"
            @onclick="HandleClick"
            @attributes="AdditionalAttributes">
        @ChildContent
        <svg xmlns="http://www.w3.org/2000/svg"
             width="16" height="16"
             viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round"
             class="cn-accordion-trigger-icon"
             data-slot="accordion-trigger-icon">
            <path d="m6 9 6 6 6-6" />
        </svg>
    </button>
</h3>

@code {
    [CascadingParameter] public RnAccordionItem? Item { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsExpanded => Item?.IsExpanded ?? false;

    private async Task HandleClick()
    {
        if (Item is not null)
            await Item.Toggle();
    }
}
