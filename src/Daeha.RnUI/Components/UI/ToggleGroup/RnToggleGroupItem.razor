@* RnToggleGroupItem - Individual item within a ToggleGroup *@

<button type="button"
        data-slot="toggle-group-item"
        data-state="@(IsActive ? "on" : "off")"
        aria-pressed="@IsActive.ToString().ToLower()"
        disabled="@(Disabled ? true : (object?)null)"
        class="@ComputedClass"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] public RnToggleGroup? Group { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>The value this item represents.</summary>
    [Parameter] public string Value { get; set; } = "";

    /// <summary>Override variant from parent group.</summary>
    [Parameter] public ToggleVariant? Variant { get; set; }

    /// <summary>Override size from parent group.</summary>
    [Parameter] public ToggleSize? Size { get; set; }

    /// <summary>Whether this item is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsActive => Group?.IsItemActive(Value) ?? false;

    private ToggleVariant EffectiveVariant => Variant ?? Group?.Variant ?? ToggleVariant.Default;
    private ToggleSize EffectiveSize => Size ?? Group?.Size ?? ToggleSize.Default;

    private string ComputedClass => CssUtils.Cn(
        "cn-toggle-group-item cn-toggle",
        EffectiveVariant switch
        {
            ToggleVariant.Outline => "cn-toggle-variant-outline",
            ToggleVariant.Primary => "cn-toggle-variant-primary",
            _ => null
        },
        EffectiveSize switch
        {
            ToggleSize.Sm => "cn-toggle-size-sm",
            ToggleSize.Lg => "cn-toggle-size-lg",
            _ => "cn-toggle-size-default"
        },
        Class
    );

    private async Task HandleClick()
    {
        if (Group is not null)
            await Group.ToggleItem(Value);
    }
}
