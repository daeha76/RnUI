@* RnComboboxItem component - Individual item within RnCombobox *@

@if (_isVisible)
{
    <div data-slot="combobox-item"
         role="option"
         aria-selected="@IsSelected"
         data-selected="@(IsSelected ? "" : null)"
         class="cn-combobox-item"
         @onclick="HandleClick">
        <span class="@CssUtils.Cn("flex size-4 items-center justify-center", IsSelected ? "opacity-100" : "opacity-0")">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"/>
            </svg>
        </span>
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @(Label ?? Value)
        }
    </div>
}

@code {
    /// <summary>The value of this item.</summary>
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;

    /// <summary>Display label for the item. Falls back to ChildContent or Value if not set.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Display content for the item.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter] private RnCombobox? Parent { get; set; }

    private bool _isVisible = true;

    private bool IsSelected => Parent?.Value == Value;

    private string DisplayLabel => Label ?? Value;

    protected override void OnParametersSet()
    {
        Parent?.RegisterItem(Value, DisplayLabel);
        _isVisible = Parent?.IsItemVisible(Value, DisplayLabel) ?? true;
    }

    private async Task HandleClick()
    {
        if (Parent is not null)
        {
            await Parent.SelectItem(Value);
        }
    }
}
