@* RnDropdownMenu component - Blazor port of shadcn/ui DropdownMenu *@
@implements IAsyncDisposable
@inject RnUIInteropService Interop

<div data-slot="dropdown-menu" class="relative inline-block" @attributes="AdditionalAttributes">
    <div @ref="_triggerRef"
         data-slot="dropdown-menu-trigger"
         aria-expanded="@_open"
         aria-haspopup="menu"
         class="cn-dropdown-menu-trigger"
         @onclick="ToggleOpen">
        @Trigger
    </div>

    @if (_open)
    {
        <CascadingValue Value="this" IsFixed="true">
            <div @ref="_contentRef"
                 data-slot="dropdown-menu-content"
                 role="menu"
                 class="@CssUtils.Cn("cn-dropdown-menu-content fixed", Class)">
                @ChildContent
            </div>
        </CascadingValue>
    }
</div>

@code {
    [Parameter] public RenderFragment? Trigger { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Alignment of the dropdown relative to its trigger.</summary>
    [Parameter] public Alignment Align { get; set; } = Alignment.Start;

    /// <summary>Side where the dropdown appears.</summary>
    [Parameter] public Side Side { get; set; } = Side.Bottom;

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private ElementReference _triggerRef;
    private ElementReference _contentRef;
    private DotNetObjectReference<RnDropdownMenu>? _dotNetRef;
    private bool _open;
    private bool _previousOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_open && !_previousOpen)
        {
            _previousOpen = true;
            await Interop.PositionDropdownAsync(
                _id, _triggerRef, _contentRef,
                Side.ToString(), Align.ToString(), 4,
                _dotNetRef!, nameof(CloseMenu));
            await Interop.AddClickOutsideListenerAsync(_id, _contentRef, _dotNetRef!, nameof(CloseMenu));
            await Interop.AddEscapeListenerAsync(_id, _dotNetRef!, nameof(CloseMenu));
        }
        else if (!_open && _previousOpen)
        {
            _previousOpen = false;
            await Interop.DisposeDropdownPositionAsync(_id);
            await Interop.DisposeAllAsync(_id);
        }
    }

    private void ToggleOpen() => _open = !_open;

    [JSInvokable]
    public Task CloseMenu()
    {
        _open = false;
        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_previousOpen)
        {
            await Interop.DisposeDropdownPositionAsync(_id);
            await Interop.DisposeAllAsync(_id);
        }
        _dotNetRef?.Dispose();
    }
}
