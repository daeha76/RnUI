@* RnNavigationMenuContent - Dropdown content for a navigation menu item *@

@if (IsOpen)
{
    <div data-slot="navigation-menu-content"
         data-state="open"
         class="@CssUtils.Cn("cn-navigation-menu-content absolute top-full left-0 w-full md:w-auto", Class)"
         @attributes="AdditionalAttributes">
        <ul class="grid gap-3 p-4 md:w-[400px] md:grid-cols-2">
            @ChildContent
        </ul>
    </div>
}

@code {
    [CascadingParameter] public RnNavigationMenuItem? MenuItem { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsOpen => MenuItem?.IsOpen ?? false;
}
