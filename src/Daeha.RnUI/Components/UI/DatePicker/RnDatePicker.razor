@* RnDatePicker component - Blazor port of shadcn/ui DatePicker *@
@implements IAsyncDisposable
@inject RnUIInteropService Interop

<div data-slot="date-picker" class="@CssUtils.Cn("relative inline-block", Class)" @attributes="AdditionalAttributes">
    <button type="button"
            data-slot="date-picker-trigger"
            disabled="@(Disabled ? true : (object?)null)"
            class="@CssUtils.Cn("cn-button cn-button-variant-outline cn-button-size-default w-[240px] justify-start text-left font-normal inline-flex items-center", Value.HasValue ? "" : "text-muted-foreground")"
            @onclick="ToggleOpen">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 size-4 shrink-0">
            <path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>
        </svg>
        @(Value.HasValue ? Value.Value.ToString(DateFormat ?? "MMM dd, yyyy") : (Placeholder ?? "Pick a date"))
    </button>

    @if (_isOpen)
    {
        <div @ref="_contentRef"
             data-slot="date-picker-content"
             class="absolute z-50 mt-1 rounded-md border bg-popover text-popover-foreground shadow-md outline-none">
            <RnCalendar Selected="Value"
                        SelectedChanged="HandleDateSelected"
                        MinDate="MinDate"
                        MaxDate="MaxDate" />
        </div>
    }
</div>

@code {
    /// <summary>Currently selected date value.</summary>
    [Parameter] public DateTime? Value { get; set; }

    /// <summary>Callback when the selected date changes.</summary>
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }

    /// <summary>Placeholder text when no date is selected.</summary>
    [Parameter] public string? Placeholder { get; set; } = "Pick a date";

    /// <summary>Display format string for the selected date.</summary>
    [Parameter] public string? DateFormat { get; set; } = "MMM dd, yyyy";

    /// <summary>Minimum selectable date (inclusive).</summary>
    [Parameter] public DateTime? MinDate { get; set; }

    /// <summary>Maximum selectable date (inclusive).</summary>
    [Parameter] public DateTime? MaxDate { get; set; }

    /// <summary>Whether the date picker is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private ElementReference _contentRef;
    private DotNetObjectReference<RnDatePicker>? _dotNetRef;
    private bool _isOpen;
    private bool _previousOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_isOpen && !_previousOpen)
        {
            _previousOpen = true;
            await Interop.AddClickOutsideListenerAsync(_id, _contentRef, _dotNetRef!, nameof(ClosePopover));
            await Interop.AddEscapeListenerAsync(_id, _dotNetRef!, nameof(ClosePopover));
        }
        else if (!_isOpen && _previousOpen)
        {
            _previousOpen = false;
            await Interop.DisposeAllAsync(_id);
        }
    }

    private void ToggleOpen()
    {
        if (!Disabled)
            _isOpen = !_isOpen;
    }

    [JSInvokable]
    public void ClosePopover()
    {
        _isOpen = false;
        StateHasChanged();
    }

    private async Task HandleDateSelected(DateTime? date)
    {
        Value = date;
        _isOpen = false;
        await ValueChanged.InvokeAsync(Value);
    }

    public async ValueTask DisposeAsync()
    {
        if (_previousOpen)
        {
            await Interop.DisposeAllAsync(_id);
        }
        _dotNetRef?.Dispose();
    }
}
