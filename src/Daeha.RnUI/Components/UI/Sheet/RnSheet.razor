@* RnSheet component - Blazor port of shadcn/ui Sheet *@
@implements IAsyncDisposable
@inject RnUIInteropService Interop

@if (_visible)
{
    <div data-slot="sheet">
        <div data-slot="sheet-overlay"
             data-state="@StateValue"
             class="cn-sheet-overlay fixed inset-0 z-50"
             @onclick="Close"></div>

        <div @ref="_contentRef"
             data-slot="sheet-content"
             data-side="@SideValue"
             data-state="@StateValue"
             role="dialog"
             aria-modal="true"
             aria-labelledby="@(_id + "-title")"
             id="@_id"
             class="@CssUtils.Cn("cn-sheet-content", Class)"
             @attributes="AdditionalAttributes">
            @ChildContent

            @if (ShowCloseButton)
            {
                <button type="button" data-slot="sheet-close" class="cn-sheet-close" @onclick="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         class="size-4">
                        <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                    </svg>
                    <span class="sr-only">Close</span>
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the sheet is open.</summary>
    [Parameter] public bool Open { get; set; }

    /// <summary>Callback when open state changes.</summary>
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>Side from which the sheet slides in.</summary>
    [Parameter] public Side Side { get; set; } = Side.Right;

    /// <summary>Whether to show the close button.</summary>
    [Parameter] public bool ShowCloseButton { get; set; } = true;

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const int CloseAnimationMs = 200;
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private ElementReference _contentRef;
    private DotNetObjectReference<RnSheet>? _dotNetRef;
    private bool _previousOpen;
    private bool _visible;
    private bool _closing;

    private string StateValue => _closing ? "closed" : "open";

    private string SideValue => Side switch
    {
        Side.Top => "top",
        Side.Bottom => "bottom",
        Side.Left => "left",
        _ => "right"
    };

    protected override async Task OnParametersSetAsync()
    {
        if (Open && !_previousOpen)
        {
            _closing = false;
            _visible = true;
            _previousOpen = true;
        }
        else if (!Open && _previousOpen && !_closing)
        {
            _closing = true;
            _previousOpen = false;
            StateHasChanged();
            await Task.Delay(CloseAnimationMs);
            _visible = false;
            _closing = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (Open && _visible && !_closing)
        {
            await Interop.LockBodyScrollAsync();
            await Interop.EnableFocusTrapAsync(_id, _contentRef);
            await Interop.AddEscapeListenerAsync(_id, _dotNetRef!, nameof(Close));
        }
        else if (!_visible)
        {
            await Interop.DisposeAllAsync(_id);
            await Interop.UnlockBodyScrollAsync();
        }
    }

    [JSInvokable]
    public async Task Close() => await OpenChanged.InvokeAsync(false);

    public async ValueTask DisposeAsync()
    {
        if (_visible)
        {
            await Interop.DisposeAllAsync(_id);
            await Interop.UnlockBodyScrollAsync();
        }
        _dotNetRef?.Dispose();
    }
}
