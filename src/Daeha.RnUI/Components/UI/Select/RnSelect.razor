@* RnSelect component - Blazor port of shadcn/ui RnSelect *@

@implements IAsyncDisposable
@inject RnUIInteropService Interop

<div data-slot="select" class="@CssUtils.Cn("relative", Class)" @ref="_rootRef" @attributes="AdditionalAttributes">
    <button type="button" data-slot="select-trigger" data-size="@SizeValue"
            class="cn-select-trigger"
            disabled="@(Disabled ? true : (object?)null)"
            aria-expanded="@(_open.ToString().ToLower())"
            aria-haspopup="listbox"
            @onclick="ToggleOpen">
        <span data-slot="select-value"
              data-placeholder="@(IsPlaceholder ? "" : null)"
              class="cn-select-value">
            @if (_selectedContent is not null)
            {
                @_selectedContent
            }
            else if (!string.IsNullOrEmpty(Value))
            {
                @Value
            }
            else
            {
                @Placeholder
            }
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="cn-select-trigger-icon">
            <path d="m6 9 6 6 6-6"/>
        </svg>
    </button>

    @if (_open)
    {
        <div data-slot="select-content" role="listbox" data-state="open" class="cn-select-content absolute mt-1">
            <CascadingValue Value="this" IsFixed="false">
                @ChildContent
            </CascadingValue>
        </div>
    }
</div>

@code {
    private ElementReference _rootRef;
    private DotNetObjectReference<RnSelect>? _dotNetRef;
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private bool _open;
    private bool _listenerActive;
    private RenderFragment? _selectedContent;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Selected value.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when the selected value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Placeholder text when no value is selected.</summary>
    [Parameter] public string? Placeholder { get; set; } = "Select...";

    /// <summary>Size of the RnSelect trigger.</summary>
    [Parameter] public ComponentSize Size { get; set; } = ComponentSize.Default;

    /// <summary>Whether the RnSelect is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string SizeValue => Size == ComponentSize.Sm ? "sm" : "default";
    private bool IsPlaceholder => _selectedContent is null && string.IsNullOrEmpty(Value);

    private void ToggleOpen() => _open = !_open;

    internal async Task SelectItem(string value, RenderFragment? content = null)
    {
        Value = value;
        _selectedContent = content;
        _open = false;
        await ValueChanged.InvokeAsync(value);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _dotNetRef = DotNetObjectReference.Create(this);

        if (_open && !_listenerActive)
        {
            await Interop.AddClickOutsideListenerAsync(_id, _rootRef, _dotNetRef!, nameof(CloseFromOutside));
            _listenerActive = true;
        }
        else if (!_open && _listenerActive)
        {
            await Interop.RemoveClickOutsideListenerAsync(_id);
            _listenerActive = false;
        }
    }

    [JSInvokable]
    public void CloseFromOutside()
    {
        _open = false;
        _listenerActive = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_listenerActive)
            await Interop.RemoveClickOutsideListenerAsync(_id);
        _dotNetRef?.Dispose();
    }
}
