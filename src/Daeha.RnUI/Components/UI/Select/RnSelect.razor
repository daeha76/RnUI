@* RnSelect component - Blazor port of shadcn/ui RnSelect *@

<div data-slot="select" class="@CssUtils.Cn("relative", Class)" @attributes="AdditionalAttributes">
    <button type="button" data-slot="select-trigger" data-size="@SizeValue"
            data-placeholder="@(string.IsNullOrEmpty(Value) ? "" : null)"
            class="cn-select-trigger"
            disabled="@(Disabled ? true : (object?)null)"
            aria-expanded="@(_open.ToString().ToLower())"
            aria-haspopup="listbox"
            @onclick="ToggleOpen">
        <span data-slot="select-value" class="cn-select-value">
            @if (!string.IsNullOrEmpty(Value))
            {
                @(_displayText ?? Value)
            }
            else
            {
                @Placeholder
            }
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="cn-select-trigger-icon">
            <path d="m6 9 6 6 6-6"/>
        </svg>
    </button>

    @if (_open)
    {
        <div data-slot="select-content" role="listbox" class="cn-select-content absolute mt-1">
            <CascadingValue Value="this" IsFixed="false">
                @ChildContent
            </CascadingValue>
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Selected value.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback when the selected value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Placeholder text when no value is selected.</summary>
    [Parameter] public string? Placeholder { get; set; } = "Select...";

    /// <summary>Size of the RnSelect trigger.</summary>
    [Parameter] public ComponentSize Size { get; set; } = ComponentSize.Default;

    /// <summary>Whether the RnSelect is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _open;
    private string? _displayText;

    private string SizeValue => Size == ComponentSize.Sm ? "sm" : "default";

    private void ToggleOpen() => _open = !_open;

    internal async Task SelectItem(string value, string? displayText = null)
    {
        Value = value;
        _displayText = displayText;
        _open = false;
        await ValueChanged.InvokeAsync(value);
    }
}
