@* RnAlert component - Blazor port of shadcn/ui Alert *@

<div data-slot="alert"
     role="alert"
     data-variant="@Variant.ToString().ToLowerInvariant()"
     class="@ComputedClass"
     @attributes="AdditionalAttributes">
    @if (Icon is not null)
    {
        @Icon
    }
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public AlertVariant Variant { get; set; } = AlertVariant.Default;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => CssUtils.Cn(
        "cn-alert",
        Variant switch {
            AlertVariant.Destructive => "cn-alert-variant-destructive",
            _ => "cn-alert-variant-default"
        },
        Class
    );
}
