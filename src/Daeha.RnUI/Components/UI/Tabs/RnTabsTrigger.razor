<RnButton type="button" data-slot="tabs-trigger" role="tab"
        id="@($"tab-trigger-{Value}")"
        data-active="@(IsActive ? "" : null)"
        aria-selected="@IsActive.ToString().ToLower()"
        aria-controls="@($"tab-content-{Value}")"
        class="@CssUtils.Cn("cn-tabs-trigger", IsActive ? "data-active:bg-background data-active:text-foreground" : "text-foreground/60", Class)"
        @onclick="HandleClick"
        @onkeydown="HandleKeyDown"
        @attributes="AdditionalAttributes">
    @ChildContent
</RnButton>

@code {
    [CascadingParameter] public RnTabs? Parent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsActive => Parent?.ActiveTab == Value;

    private async Task HandleClick()
    {
        if (Parent is not null)
            await Parent.SetActiveTab(Value);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await HandleClick();
    }
}
