@* RnButtonGroup component - Blazor port of shadcn/ui ButtonGroup *@

<div role="group"
     data-slot="button-group"
     data-orientation="@OrientationValue"
     class="@ComputedClass"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public ButtonGroupOrientation Orientation { get; set; } = ButtonGroupOrientation.Horizontal;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string OrientationValue => Orientation == ButtonGroupOrientation.Vertical ? "vertical" : "horizontal";

    private string ComputedClass => CssUtils.Cn(
        "cn-button-group",
        Orientation == ButtonGroupOrientation.Vertical
            ? "cn-button-group-vertical"
            : "cn-button-group-horizontal",
        Class
    );
}
