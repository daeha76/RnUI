@* RnHoverCard component - Blazor port of shadcn/ui RnHoverCard *@
@implements IAsyncDisposable
@inject RnUIInteropService Interop

<div data-slot="hover-card" class="relative inline-block"
     @onmouseenter="Show" @onmouseleave="Hide"
     @attributes="AdditionalAttributes">
    <div data-slot="hover-card-trigger">
        @Trigger
    </div>

    @if (_visible)
    {
        <div data-slot="hover-card-content"
             class="@CssUtils.Cn("cn-hover-card-content absolute z-50", Class)"
             style="@PositionUtils.GetPositionStyle(Side, Align)">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? Trigger { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Side where the hover RnCard appears.</summary>
    [Parameter] public Side Side { get; set; } = Side.Bottom;

    /// <summary>Alignment of the hover card.</summary>
    [Parameter] public Alignment Align { get; set; } = Alignment.Center;

    /// <summary>Additional CSS classes.</summary>
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private DotNetObjectReference<RnHoverCard>? _dotNetRef;
    private bool _visible;
    private bool _previousVisible;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_visible && !_previousVisible)
        {
            _previousVisible = true;
            await Interop.AddEscapeListenerAsync(_id, _dotNetRef!, nameof(HideCard));
        }
        else if (!_visible && _previousVisible)
        {
            _previousVisible = false;
            await Interop.RemoveEscapeListenerAsync(_id);
        }
    }

    private void Show() => _visible = true;
    private void Hide() => _visible = false;

    [JSInvokable]
    public void HideCard()
    {
        _visible = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_previousVisible)
        {
            await Interop.RemoveEscapeListenerAsync(_id);
        }
        _dotNetRef?.Dispose();
    }
}
