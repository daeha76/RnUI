@* RnPagination component - Blazor port of shadcn/ui RnPagination *@

<nav data-slot="pagination" role="navigation" aria-label="pagination"
     class="@CssUtils.Cn("cn-pagination mx-auto flex w-full justify-center", Class)"
     @attributes="AdditionalAttributes">
    <ul class="cn-pagination-content flex flex-row items-center gap-1">
        @if (CurrentPage > 1)
        {
            <li class="cn-pagination-item">
                <RnButton type="button" class="cn-pagination-link" @onclick="() => GoToPage(CurrentPage - 1)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"/>
                    </svg>
                    <span>Previous</span>
                </RnButton>
            </li>
        }

        @foreach (var item in GetPageNumbers())
        {
            @if (item.IsEllipsis)
            {
                <li class="cn-pagination-item">
                    <span class="cn-pagination-ellipsis flex h-9 w-9 items-center justify-center">&#8230;</span>
                </li>
            }
            else
            {
                var page = item.Page!.Value;
                <li class="cn-pagination-item">
                    <RnButton type="button"
                            class="cn-pagination-link"
                            data-active="@(page == CurrentPage ? "" : null)"
                            @onclick="() => GoToPage(page)">
                        @(page)
                    </RnButton>
                </li>
            }
        }

        @if (CurrentPage < TotalPages)
        {
            <li class="cn-pagination-item">
                <RnButton type="button" class="cn-pagination-link" @onclick="() => GoToPage(CurrentPage + 1)">
                    <span>Next</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"/>
                    </svg>
                </RnButton>
            </li>
        }
    </ul>
</nav>

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task GoToPage(int page)
    {
        CurrentPage = page;
        await CurrentPageChanged.InvokeAsync(page);
    }

    private IEnumerable<(int? Page, bool IsEllipsis)> GetPageNumbers()
    {
        var pages = new List<(int?, bool)>();

        if (TotalPages <= 7)
        {
            for (int i = 1; i <= TotalPages; i++)
                pages.Add((i, false));
            return pages;
        }

        // Always first page
        pages.Add((1, false));

        if (CurrentPage > 3)
            pages.Add((null, true)); // Leading ellipsis

        // Pages around current
        int start = Math.Max(2, CurrentPage - 1);
        int end = Math.Min(TotalPages - 1, CurrentPage + 1);

        for (int i = start; i <= end; i++)
            pages.Add((i, false));

        if (CurrentPage < TotalPages - 2)
            pages.Add((null, true)); // Trailing ellipsis

        // Always last page
        pages.Add((TotalPages, false));

        return pages;
    }
}
