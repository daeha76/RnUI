@* RnPagination component - Blazor port of shadcn/ui RnPagination *@

<nav data-slot="pagination" role="navigation" aria-label="pagination"
     class="@CssUtils.Cn("cn-pagination", Class)"
     @attributes="AdditionalAttributes">
    <ul class="cn-pagination-content">
        @if (CurrentPage > 1)
        {
            <li data-slot="pagination-item" class="cn-pagination-item">
                <button type="button" data-slot="pagination-previous"
                        class="cn-pagination-link gap-1 pl-2.5"
                        aria-label="Go to previous page"
                        @onclick="() => GoToPage(CurrentPage - 1)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"/>
                    </svg>
                    <span>Previous</span>
                </button>
            </li>
        }

        @foreach (var item in GetPageNumbers())
        {
            @if (item.IsEllipsis)
            {
                <li data-slot="pagination-item" class="cn-pagination-item">
                    <span data-slot="pagination-ellipsis" class="cn-pagination-link" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
                        </svg>
                        <span class="sr-only">More pages</span>
                    </span>
                </li>
            }
            else
            {
                var page = item.Page!.Value;
                <li data-slot="pagination-item" class="cn-pagination-item">
                    <button type="button"
                            data-slot="pagination-link"
                            data-active="@(page == CurrentPage ? "" : null)"
                            aria-current="@(page == CurrentPage ? "page" : null)"
                            class="cn-pagination-link"
                            @onclick="() => GoToPage(page)">
                        @(page)
                    </button>
                </li>
            }
        }

        @if (CurrentPage < TotalPages)
        {
            <li data-slot="pagination-item" class="cn-pagination-item">
                <button type="button" data-slot="pagination-next"
                        class="cn-pagination-link gap-1 pr-2.5"
                        aria-label="Go to next page"
                        @onclick="() => GoToPage(CurrentPage + 1)">
                    <span>Next</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"/>
                    </svg>
                </button>
            </li>
        }
    </ul>
</nav>

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task GoToPage(int page)
    {
        CurrentPage = page;
        await CurrentPageChanged.InvokeAsync(page);
    }

    private IEnumerable<(int? Page, bool IsEllipsis)> GetPageNumbers()
    {
        var pages = new List<(int?, bool)>();

        if (TotalPages <= 7)
        {
            for (int i = 1; i <= TotalPages; i++)
                pages.Add((i, false));
            return pages;
        }

        pages.Add((1, false));

        if (CurrentPage > 3)
            pages.Add((null, true));

        int start = Math.Max(2, CurrentPage - 1);
        int end = Math.Min(TotalPages - 1, CurrentPage + 1);

        for (int i = start; i <= end; i++)
            pages.Add((i, false));

        if (CurrentPage < TotalPages - 2)
            pages.Add((null, true));

        pages.Add((TotalPages, false));

        return pages;
    }
}
